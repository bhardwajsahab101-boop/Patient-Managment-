<%- layout("./layout/auth.ejs") %>

<style>
  /* Make auth layout card wider for this page.
     Note: auth layout wraps the page with: <div class="auth-card">...</div>
     (outside of .pending-wrapper), so we must target .auth-card directly. */
  .auth-card {
    max-width: 980px;
    width: calc(100% - 2rem);
    padding: 2.5rem 2rem;
  }

  /* Keep the content readable on very wide screens */
  .pending-wrapper {
    margin: 0 auto;
    max-width: 980px;
  }

  /* Slightly reduce padding on tablets/mobile */
  @media (max-width: 768px) {
    .auth-card {
      max-width: 520px;
      width: 100%;
      padding: 1.75rem 1.25rem;
    }
  }

  /* Value statement */
  .value-statement {
    text-align: center;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  /* Pricing comparison */
  .pricing-comparison {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .plan-card {
    flex: 1;
    border: 2px solid #e5e7eb;
    border-radius: 12px;
    padding: 1rem;
    text-align: center;
    opacity: 0.7;
    transition: all 0.2s ease;
  }

  .plan-card.active {
    border-color: #0d6efd;
    opacity: 1;
    background: #eff6ff;
    position: relative;
  }

  .plan-card .plan-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: #0d6efd;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 10px;
    white-space: nowrap;
  }

  .plan-card h4 {
    font-size: 0.9rem;
    font-weight: 700;
    color: #374151;
    margin-bottom: 0.25rem;
  }

  .plan-card .plan-price {
    font-size: 1.1rem;
    font-weight: 800;
    color: #1f2937;
  }

  /* Main pricing card */
  .pricing-card {
    border: 2px solid #0d6efd;
    border-radius: 16px;
    padding: 1.75rem;
    text-align: center;
    margin-bottom: 1.5rem;
    background: linear-gradient(180deg, #fff 0%, #f8fafc 100%);
  }

  .pricing-card h3 {
    font-size: 1.25rem;
    font-weight: 800;
    color: #1f2937;
    margin-bottom: 0.25rem;
  }

  .pricing-card .price {
    font-size: 2rem;
    font-weight: 900;
    color: #0d6efd;
    margin-bottom: 1rem;
  }

  .feature-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    text-align: left;
  }

  .feature-list li {
    padding: 0.4rem 0;
    font-size: 0.95rem;
    color: #374151;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .feature-list li i {
    color: #10b981;
    font-size: 1rem;
  }

  .btn-activate {
    background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 100%);
    border: none;
    color: #fff;
    font-weight: 700;
    font-size: 1.05rem;
    padding: 0.85rem 1.5rem;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease;
    width: 100%;
    justify-content: center;
  }

  .btn-activate:hover {
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(13, 110, 253, 0.3);
  }

  /* WhatsApp CTA */
  .whatsapp-section {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .whatsapp-section p {
    color: #065f46;
    font-weight: 600;
    margin-bottom: 0.75rem;
    font-size: 1rem;
  }

  .btn-whatsapp {
    background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);
    border: none;
    color: #fff;
    font-weight: 700;
    font-size: 1.05rem;
    padding: 0.85rem 1.5rem;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease;
    width: 100%;
    justify-content: center;
  }

  .btn-whatsapp:hover {
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(37, 211, 102, 0.35);
  }

  /* Why choose us */
  .why-section {
    margin-bottom: 1.5rem;
  }

  .why-section h4 {
    text-align: center;
    font-size: 1rem;
    font-weight: 700;
    color: #374151;
    margin-bottom: 0.75rem;
  }

  .why-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .why-list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0;
    font-size: 0.9rem;
    color: #4b5563;
  }

  .why-list li i {
    color: #f59e0b;
    font-size: 0.9rem;
  }

  /* Support & logout */
  .support-note {
    text-align: center;
    font-size: 0.85rem;
    color: #9ca3af;
    margin-bottom: 1.25rem;
  }

  .logout-link {
    text-align: center;
    font-size: 0.85rem;
    color: #9ca3af;
  }

  .logout-link button {
    background: none;
    border: none;
    color: #6b7280;
    text-decoration: underline;
    padding: 0;
    cursor: pointer;
    font-size: 0.85rem;
  }

  .logout-link button:hover {
    color: #374151;
  }

  /* Button inside cards */
  .btn-choose {
    background: #ffffff;
    border: 1px solid #cbd5e1;
    color: #0d6efd;
    font-weight: 800;
    padding: 0.6rem 1rem;
    border-radius: 12px;
    transition: all 0.15s ease;
    width: 100%;
    display: inline-flex;
    justify-content: center;
    align-items: center;
  }

  .btn-choose:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(13, 110, 253, 0.15);
  }

  .plan-card.active .btn-choose {
    background: #0d6efd;
    border-color: #0d6efd;
    color: #fff;
  }
</style>

<div class="pending-wrapper">
  <p class="value-statement">
    Manage patients, medicines, and clinic records in one place.
  </p>

  <% if (showRenewal) { %>
    <div class="alert alert-warning" style="text-align:center; margin-bottom: 1.25rem;">
      <i class="fa-solid fa-triangle-exclamation me-2"></i>
      <strong><%= title %></strong>
      <div style="margin-top:0.5rem; color:#374151; font-weight:600;">
        <%= message %>
      </div>
    </div>

    <div style="margin-bottom: 1.25rem; text-align:center;">
      <a href="/support" class="btn-activate" style="display:inline-block; width: 100%; max-width: 360px;">
        <i class="fa-solid fa-headset me-2"></i>Contact Support
      </a>
    </div>
  <% } %>

  <div class="pricing-comparison" style="display: <%= showRenewal ? 'none' : 'flex' %>">
    <div
      class="plan-card <%= (((typeof selectedPlan !== 'undefined') ? selectedPlan : '') || '').toLowerCase() === 'starter' ? 'active' : '' %>"
      role="button"
      tabindex="0"
      data-plan="starter"
      aria-pressed="<%= ((typeof selectedPlan !== 'undefined') ? selectedPlan : '') === 'starter' %>"
    >
      <h4>Starter</h4>
      <div class="plan-price">₹499</div>
      <small class="text-muted">/ month</small>

      <ul class="feature-list mt-3 mb-0">
        <li><i class="fa-solid fa-check"></i> 14-day free trial</li>
        <li><i class="fa-solid fa-check"></i> Patient management</li>
        <li><i class="fa-solid fa-check"></i> Medicine tracking</li>
        <li><i class="fa-solid fa-check"></i> Reports</li>
        <li><i class="fa-solid fa-check"></i> Support</li>
      </ul>

      <form
        method="POST"
        action="/account-pending/activate-trial?plan=starter"
        style="margin: 0"
      >
        <button type="submit" class="btn-choose" data-trial-action="starter">
          Activate 14-Day Free Trial
        </button>
      </form>
    </div>

    <div
      class="plan-card <%= ((typeof selectedPlan !== 'undefined') ? selectedPlan : '') === 'pro' ? 'active' : '' %>"
      role="button"
      tabindex="0"
      data-plan="pro"
      aria-pressed="<%= ((typeof selectedPlan !== 'undefined') ? selectedPlan : '') === 'pro' %>"
    >
      <div class="plan-badge">Most Popular</div>
      <h4>Pro</h4>
      <div class="plan-price">₹999</div>
      <small class="text-muted">/ month</small>

      <ul class="feature-list mt-3 mb-0">
        <li><i class="fa-solid fa-check"></i> All Starter features</li>
        <li><i class="fa-solid fa-check"></i> 14-day free trial</li>
        <li><i class="fa-solid fa-check"></i> Multi-clinic support</li>
 
        <li><i class="fa-solid fa-check"></i> Advanced analytics</li>
        <li><i class="fa-solid fa-check"></i> Export/backup</li>
      </ul>

      <form
        method="POST"
        action="/account-pending/activate-trial?plan=pro"
        style="margin: 0"
      >
        <button type="submit" class="btn-choose" data-trial-action="pro">
          Activate 14-Day Free Trial
        </button>
      </form>
    </div>
  </div>

  <div class="pricing-card" style="display: <%= showRenewal ? 'none' : 'block' %>">
    <h3 class="mb-3">Activate your selected plan</h3>
    <p class="text-muted mb-3" id="selectedPlanText">No plan selected yet.</p>

    <a
      id="activateCta"
      data-user-name="<%= encodeURIComponent(userName || '') %>"
      href="https://wa.me/918950817515?text=Hi%20MediCare%20Hub%2C%20I%20just%20signed%20up%20and%20want%20to%20activate%20my%20account."
      target="_blank"
      class="btn-activate"
    >
      <i class="fa-brands fa-whatsapp"></i>
      Activate Now
    </a>
  </div>

  <div class="whatsapp-section" style="display: <%= showRenewal ? 'none' : 'block' %>;">
    <p>👋 Prefer to chat? Activate via WhatsApp directly</p>
    <a
      href="https://wa.me/918950817515?text=Hi%20MediCare%20Hub%2C%20I%20just%20signed%20up%20and%20want%20to%20activate%20my%20account.%20My%20name%20is%20<%= encodeURIComponent(userName || '') %>."
      target="_blank"
      class="btn-whatsapp"
    >
      <i class="fa-brands fa-whatsapp"></i>
      Activate via WhatsApp
    </a>
  </div>

  <div class="why-section" style="display: <%= showRenewal ? 'none' : 'block' %>;">
    <h4>Why choose us?</h4>
    <ul class="why-list">
      <li><i class="fa-solid fa-star"></i> Trusted by 500+ clinics</li>
      <li><i class="fa-solid fa-star"></i> Simple & secure</li>
      <li><i class="fa-solid fa-star"></i> No setup hassle</li>
      <li><i class="fa-solid fa-star"></i> Instant activation</li>
    </ul>
  </div>

  <p class="support-note" style="display: <%= showRenewal ? 'none' : 'block' %>;">
    📧 Prefer email? <a href="/support">Send us a message</a>
  </p>

  <form action="/logout" method="POST" class="logout-link" style="display: <%= showRenewal ? 'none' : 'block' %>;">
    <button type="submit">
      <i class="fa-solid fa-arrow-right-from-bracket me-1"></i> Logout
    </button>
  </form>

  <%- include("./_account_pending_plan_js.ejs") %>
</div>
