<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pricing - DentaCore</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="/css/landing.css" />
  </head>

  <body class="landing-page">
    <nav class="landing-navbar d-flex align-items-center px-4">
      <div class="container d-flex align-items-center justify-content-between">
        <a class="navbar-brand" href="/">DentaCore</a>
        <div class="d-flex align-items-center gap-2">
          <% if (currentUser) { %>
            <a href="/dashboard" class="btn btn-primary nav-btn">
              <i class="fas fa-columns me-1"></i> Dashboard
            </a>
            <form action="/logout" method="POST" class="d-inline m-0">
              <button type="submit" class="btn btn-outline-light nav-btn">
                <i class="fas fa-sign-out-alt me-1"></i> Logout
              </button>
            </form>
          <% } else { %>
            <a href="/login" class="btn btn-outline-light nav-btn d-none d-md-inline-block">Login</a>
            <a href="/signup" class="btn btn-primary nav-btn">Sign Up</a>
          <% } %>
        </div>
      </div>
    </nav>

    <main class="container py-5">
      <div class="text-center mb-5">
        <h1 class="fw-bold">Pricing</h1>
        <p class="text-muted mb-0">
          Start with Starter or upgrade to Pro for multi-clinic workflows and exports.
        </p>
      </div>

      <div class="row g-4 align-items-stretch">
        <div class="col-lg-4">
          <div class="card shadow-sm h-100 border-0" style="background:#fff; border-radius:18px;">
            <div class="card-body p-4">
              <h4 class="text-center mb-2">Starter</h4>
              <p class="text-center text-muted mb-4">₹499/month</p>
              <div class="list-group list-group-flush">
                <div class="list-group-item">Good for: single clinics</div>
                <div class="list-group-item">Good for: smaller practices</div>
                <div class="list-group-item">Good for: basic workflow</div>
              </div>
              <hr />
              <ul class="list-unstyled mb-4">
                <li>✓ Patient management</li>
                <li>✓ Prescription printing</li>
                <li>✓ Medicine inventory</li>
                <li>✓ Reports</li>
                <li>✓ 14-day free trial</li>
                <li>✓ WhatsApp support</li>
                <li>✓ Free setup</li>
              </ul>
              <a href="/signup" class="btn btn-primary w-100">Start Trial</a>
            </div>
          </div>
        </div>

        <div class="col-lg-4">
          <div
            class="card shadow-lg h-100 border-0 position-relative"
            style="background: linear-gradient(135deg, #0b5fff 0%, #19a2ff 100%); border-radius:18px; color:white;"
          >
            <div class="position-absolute top-0 start-50 translate-middle-x" style="transform: translate(-50%, -50%);">
              <div style="background: rgba(255,255,255,0.95); color:#0b5fff; font-weight:700; padding:8px 14px; border-radius:999px;">
                Most Popular
              </div>
            </div>

            <div class="card-body p-4 pt-5">
              <h4 class="text-center mb-2">Pro</h4>
              <p class="text-center text-light-50 mb-4">₹999/month</p>
              <div class="list-group" style="background: transparent; border-radius:14px;">
                <div class="list-group-item" style="background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.18); color:white;">Good for: growing clinics</div>
                <div class="list-group-item" style="background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.18); color:white;">Good for: multiple branches</div>
                <div class="list-group-item" style="background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.18); color:white;">Good for: heavier usage</div>
              </div>
              <hr style="border-color: rgba(255,255,255,0.35)" />
              <ul class="list-unstyled mb-4">
                <li>✓ Multi-clinic support</li>
                <li>✓ Staff management (Upcoming)</li>

                <li>✓ Advanced analytics</li>
                <li>✓ Reminder automation</li>
                <li>✓ Priority support</li>
                <li>✓ Data export/backup</li>
              </ul>
              <a href="/signup" class="btn btn-light w-100" style="font-weight:700;">Upgrade to Pro</a>
            </div>
          </div>
        </div>

        <div class="col-lg-4">
          <div class="card shadow-sm h-100 border-0" style="background:#fff; border-radius:18px;">
            <div class="card-body p-4">
              <h4 class="mb-2">Recommended</h4>
              <p class="text-muted">
                At ₹999, your software feels like a serious business tool.
              </p>
              <div class="p-3 rounded" style="background:#f0f7ff;">
                <div style="font-weight:800;">What you get next</div>
                <ul class="mb-0">
                  <li>Exports/backup</li>
                  <li>Pro-only analytics</li>
                  <li>Automation-ready reminders</li>
                </ul>
              </div>
              <div class="mt-4">
                <a href="/support" class="btn btn-outline-primary w-100">
                  Contact via WhatsApp Support
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-5">
        <p class="text-muted mb-0">
          No payment gateway implemented yet. Contact support to activate Pro.
        </p>
      </div>
    </main>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/js/all.min.js"></script>
  </body>
</html>

