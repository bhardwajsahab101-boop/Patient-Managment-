
<%- layout("./layout/boilerPlate.ejs") %>



<div class="patient-header">

  <div class="left">
    <div class="avatar">
      <%= patient.name.charAt(0).toUpperCase() %>
    </div>

    <div>
      <h2><%= patient.name %></h2>
      <p><%= patient.age %> yrs • <%= patient.gender %></p>
      <p>📞 <%= patient.phone %></p>
      <% if (patient.address) { %>
        <p>📍 <%= patient.address %></p>
      <% } %>
    </div>
  </div>

  <div class="right">
    <% 
      const today = new Date(); today.setHours(0,0,0,0);
      const next = patient.nextVisit ? new Date(patient.nextVisit) : null;
      if(next) next.setHours(0,0,0,0);
    %>

<% if(!next){ %>
      <span class="badge bg-secondary">No Visit</span>
    <% } else if(next < today){ %>
      <span class="badge bg-danger">Overdue</span>
    <% } else if(next.getTime() === today.getTime()){ %>
      <span class="badge bg-warning text-dark">Today</span>
    <% } else { %>
      <span class="badge bg-success">Upcoming</span>
    <% } %>

    <!-- Payment Summary -->
    <div class="payment-summary mt-3">
      <div class="row text-center">
        <div class="col-4">
          <div class="payment-box">
            <small class="text-muted">Total</small>
            <div class="h5 text-primary">₹<%= patient.totalPaymnt || 0 %></div>
          </div>
        </div>
        <div class="col-4">
          <div class="payment-box">
            <small class="text-muted">Paid</small>
            <div class="h5 text-success">₹<%= patient.paidPayment || 0 %></div>
          </div>
        </div>
        <div class="col-4">
          <div class="payment-box">
            <small class="text-muted">Pending</small>
            <div class="h5 text-danger">₹<%= typeof patient.pendingPayment !== 'undefined' ? patient.pendingPayment : (patient.totalPayment - patient.paidPayment) || 0 %></div>
          </div>
        </div>
      </div>
    </div>

    <p class="mt-2">
      Next Visit: 
      <strong>
        <%= next ? next.toDateString() : "Not Scheduled" %>
      </strong>
    </p>
  </div>

</div>

<div class="action-bar btn-action-bar">
  <a href="/patients/<%= patient._id %>/visits/new" class="btn btn-action btn-primary-action">
    <i class="fas fa-plus-circle"></i> Add Visit
  </a>
  <a href="/message/<%= patient._id %>" class="btn btn-action btn-whatsapp-action">
    <i class="fab fa-whatsapp"></i> WhatsApp
  </a>
  <a href="/patients/<%= patient._id %>/edit" class="btn btn-action btn-edit-action">
    <i class="fas fa-edit"></i> Edit
  </a>
  <a href="/patients/<%= patient._id %>/delete" class="btn btn-action btn-delete-action">
    <i class="fas fa-trash-alt"></i> Delete
  </a>
  <a href="/patients" class="btn btn-action btn-back-action">
    <i class="fas fa-arrow-left"></i> Back
  </a>
</div>

<div class="visit-section">
  <h4>Visit History</h4>

  <% 
    // Calculate grand total and paid totals directly from visits
    let grandTotal = 0;
    let totalPaid = 0;
    if (patient.visits && patient.visits.length) {
      patient.visits.forEach(v => {
        grandTotal += (v.price || 0);
        totalPaid += (v.paidAmount || 0);
      });
    }
    const displayPending = Math.max(0, grandTotal - totalPaid);
  %>

<% if (patient.visits && patient.visits.length > 0) { %>
    <!-- Grand Total Summary - Enhanced Visuals -->
    <div class="alert alert-info mb-4" style="background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%); border: none; padding: 20px;">
      <div class="row text-center">
        <div class="col-4">
          <small class="text-dark text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Total All Visits</small>
          <div class="h3 mb-0 text-primary" style="font-weight: 700;">₹<%= grandTotal.toFixed(0) %></div>
        </div>
        <div class="col-4">
          <small class="text-dark text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Paid</small>
          <div class="h3 mb-0 text-success" style="font-weight: 700;">₹<%= totalPaid.toFixed(0) %></div>
        </div>
        <div class="col-4">
          <small class="text-dark text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Pending</small>
          <div class="h3 mb-0 text-danger" style="font-weight: 700;">₹<%= displayPending.toFixed(0) %></div>
        </div>
      </div>
    </div>
  <% } %>

  <% if (!patient.visits || patient.visits.length === 0) { %>
    <p class="text-muted">No visits yet</p>
  <% } %>

<% 
  // Reverse visits for display (newest first)
  var visitsArr = patient.visits ? patient.visits.slice().reverse() : [];
%>

<% visitsArr.forEach(function(v, idx) { 
  var displayIdx = visitsArr.length - idx; // Show 1-based index
  var visitPrice = v && v.price ? Number(v.price) : 0;
  var visitPaid = v && typeof v.paidAmount !== 'undefined' && v.paidAmount !== null
    ? Number(v.paidAmount)
    : visitPrice;
  var visitPending = visitPrice - visitPaid;
  if (visitPending < 0) visitPending = 0;
%>

    <div class="visit-card">

      <div class="visit-top">
        <strong><%= v && v.date ? new Date(v.date).toDateString() : 'Unknown Date' %> (Visit #<%= displayIdx %>)</strong>
        <span class="price">₹<%= visitPrice.toFixed(0) %></span>
      </div>

      <!-- Visit Payment Details -->
      <div class="visit-payment-row mt-2 mb-2">
        <div class="row text-center small">
          <div class="col-4">
            <small class="text-muted">Charge</small>
            <div class="fw-bold text-primary">₹<%= visitPrice.toFixed(0) %></div>
          </div>
          <div class="col-4">
            <small class="text-muted">Paid</small>
            <div class="fw-bold text-success">₹<%= visitPaid.toFixed(0) %></div>
          </div>
          <div class="col-4">
            <small class="text-muted">Pending</small>
            <div class="fw-bold <%= visitPending > 0 ? 'text-danger' : 'text-success' %>">₹<%= visitPending.toFixed(0) %></div>
          </div>
        </div>
      </div>
      
      <% if (visitPending > 0) { %>
        <a href="/patients/<%= patient._id %>/visit/<%= idx %>/pay" class="btn btn-sm btn-success mb-2">
          <i class="fas fa-rupee-sign"></i> Pay Pending ₹<%= visitPending.toFixed(0) %>
        </a>
      <% } else { %>
        <span class="badge bg-success mb-2"><i class="fas fa-check"></i> Paid</span>
      <% } %>

      <p class="notes">
        <%= v && v.notes ? v.notes : "No notes added" %>
      </p>

      <% if (v && v.medicines && v.medicines.length > 0) { %>
        <div class="medicines-section">
          <strong><i class="fas fa-pills text-primary"></i> Prescribed Medicines:</strong>
          <div class="medicine-tags">
            <% v.medicines.forEach(function(med) { %>
              <span class="medicine-tag">
                <%= med.name %> 
                <% if (med.dosage) { %><small>(<%= med.dosage %>)</small><% } %>
                <span class="qty">x<%= med.quantity %></span>
              </span>
            <% }) %>
          </div>
        </div>
        <div class="visit-actions">
          <a href="/prescription/<%= patient._id %>/<%= idx %>" 
             class="btn btn-sm btn-outline-primary" title="View Prescription">
            📋 View Prescription
          </a>
          <a href="/prescription/<%= patient._id %>/<%= idx %>?print=true" 
            class="btn btn-sm btn-primary" target="_blank" title="Print">
            🖨️ Print
          </a>
        </div>
      <% } else { %>
        <div class="no-medicines">No medicines prescribed this visit</div>
      <% } %>

      <% if(v && v.nextVisit){ %>
        <small class="text-muted">
          Next Visit: <%= new Date(v.nextVisit).toDateString() %>
        </small>
      <% } %>

    </div>

<% }) %>
</div>
<style>
    .patient-header {
  display: flex;
  justify-content: space-between;
  background: white;
  padding: 20px;
  border-radius: 12px;
  margin-bottom: 20px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.05);
}

.patient-header .left {
  display: flex;
  gap: 15px;
  align-items: center;
}

.avatar {
  width: 60px;
  height: 60px;
  background: #0d6efd;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  font-weight: bold;
}

/* === Beautiful Action Bar Styles === */
.btn-action-bar {
  display: flex;
  gap: 12px;
  margin-bottom: 20px;
  flex-wrap: wrap;
  justify-content: flex-start;
}

.btn-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px 24px;
  border-radius: 12px;
  font-weight: 600;
  font-size: 0.95rem;
  text-decoration: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.1);
  border: none;
  cursor: pointer;
}

.btn-action i {
  font-size: 1rem;
}

/* Primary - Add Visit */
.btn-primary-action {
  background: linear-gradient(135deg, #0d6efd, #0b5ed7);
  color: white;
}
.btn-primary-action:hover {
  background: linear-gradient(135deg, #0b5ed7, #0954c4);
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(13, 110, 253, 0.35);
}

/* WhatsApp */
.btn-whatsapp-action {
  background: linear-gradient(135deg, #25D366, #128C7E);
  color: white;
}
.btn-whatsapp-action:hover {
  background: linear-gradient(135deg, #128C7E, #075e54);
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(37, 211, 102, 0.35);
}

/* Edit */
.btn-edit-action {
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  color: #1e293b;
}
.btn-edit-action:hover {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(251, 191, 36, 0.4);
}

/* Delete */
.btn-delete-action {
  background: linear-gradient(135deg, #ef4444, #dc2626);
  color: white;
}
.btn-delete-action:hover {
  background: linear-gradient(135deg, #dc2626, #b91c1c);
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(239, 68, 68, 0.4);
}

/* Back */
.btn-back-action {
  background: white;
  color: #475569;
  border: 2px solid #e2e8f0;
}
.btn-back-action:hover {
  background: #f8fafc;
  border-color: #cbd5e1;
  color: #1e293b;
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
}

/* Visit Actions */
.visit-actions {
  display: flex;
  gap: 10px;
  margin-top: 12px;
  flex-wrap: wrap;
}

.visit-actions .btn {
  padding: 8px 16px;
  border-radius: 8px;
  font-weight: 500;
  font-size: 0.85rem;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

/* Mobile responsive */
@media (max-width: 576px) {
  .btn-action-bar {
    flex-direction: column;
    width: 100%;
  }
  .btn-action {
    width: 100%;
    text-align: center;
    margin-bottom: 0.5rem;
  }
  .btn-action-bar .btn-action:last-child {
    margin-bottom: 0;
  }
}

.visit-section {
  background: white;
  padding: 20px;
  border-radius: 12px;
}

.visit-card {
  border-left: 4px solid #0d6efd;
  padding: 12px 15px;
  margin-bottom: 15px;
  background: #f8fafc;
  border-radius: 8px;
}

.visit-top {
  display: flex;
  justify-content: space-between;
}

.price {
  font-weight: bold;
  color: #16a34a;
}

.medicines-section {
  margin: 10px 0;
  padding: 8px 12px;
  background: #e8f4fd;
  border-radius: 8px;
}

.medicine-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 6px;
}

.medicine-tag {
  background: #0d6efd;
  color: white;
  padding: 4px 10px;
  border-radius: 15px;
  font-size: 0.85rem;
}

.medicine-tag .qty {
  background: rgba(255,255,255,0.3);
  padding: 1px 6px;
  border-radius: 10px;
  margin-left: 4px;
  font-weight: bold;
}

/* Visit Payment Row - Enhanced Visuals */
.visit-payment-row {
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  padding: 12px;
  border-radius: 10px;
  border: 1px solid #e2e8f0;
}

.visit-payment-row .col-4 {
  padding: 4px 8px;
}

.visit-payment-row .col-4:not(:last-child) {
  border-right: 1px solid #cbd5e1;
}

.visit-payment-row small {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.visit-payment-row .fw-bold {
  font-size: 1.1rem;
}

/* Pay Button */
.visit-card .btn-success {
  background: linear-gradient(135deg, #22c55e, #16a34a);
  border: none;
  font-weight: 600;
  padding: 8px 16px;
  border-radius: 8px;
}

.visit-card .btn-success:hover {
  background: linear-gradient(135deg, #16a34a, #15803d);
  transform: translateY(-2px);
}

/* Paid Badge */
.badge.bg-success {
  background: linear-gradient(135deg, #22c55e, #16a34a) !important;
  padding: 8px 12px;
  font-size: 0.8rem;
  border-radius: 20px;
}
</style>

