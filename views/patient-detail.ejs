
<%- layout("./layout/boilerPlate.ejs") %>



<div class="patient-header">

  <div class="left">
    <div class="avatar">
      <%= patient.name.charAt(0).toUpperCase() %>
    </div>

    <div>
      <h2><%= patient.name %></h2>
      <p><%= patient.age %> yrs • <%= patient.gender %></p>
      <p>📞 <%= patient.phone %></p>
    </div>
  </div>

  <div class="right">
    <% 
      const today = new Date(); today.setHours(0,0,0,0);
      const next = patient.nextVisit ? new Date(patient.nextVisit) : null;
      if(next) next.setHours(0,0,0,0);
    %>

    <% if(!next){ %>
      <span class="badge bg-secondary">No Visit</span>
    <% } else if(next < today){ %>
      <span class="badge bg-danger">Overdue</span>
    <% } else if(next.getTime() === today.getTime()){ %>
      <span class="badge bg-warning text-dark">Today</span>
    <% } else { %>
      <span class="badge bg-success">Upcoming</span>
    <% } %>

    <p class="mt-2">
      Next Visit: 
      <strong>
        <%= next ? next.toDateString() : "Not Scheduled" %>
      </strong>
    </p>
  </div>

</div>

<div class="action-bar">
  <a href="/patients/<%= patient._id %>/visits/new" class="btn btn-primary">
    ➕ Add Visit
  </a>
  <a href="/message/<%= patient._id %>" class="btn btn-success">
    WhatsApp
  </a>
  <a href="/patients/<%= patient._id %>/delete" class="btn btn-sm btn-outline-danger "><i class="fas fa-trash me-1"></i>Delete</a>
<a href="/patients/<%= patient._id %>/edit" class="btn btn-sm btn-outline-warning "><i class="fas fa-edit me-1"></i>Edit</a>

  <a href="/patients" class="btn btn-outline-secondary">
    Back
  </a>
</div>

<div class="visit-section">
  <h4>Visit History</h4>

  <% if (!patient.visits.length) { %>
    <p class="text-muted">No visits yet</p>
  <% } %>

  <% patient.visits.slice().reverse().forEach(v => { %>

    <div class="visit-card">

      <div class="visit-top">
        <strong><%= new Date(v.date).toDateString() %></strong>
        <span class="price">₹<%= v.price || 0 %></span>
      </div>

      <p class="notes">
        <%= v.notes || "No notes added" %>
      </p>

      <% if (v.medicines && v.medicines.length > 0) { %>
        <div class="medicines-section">
          <strong><i class="fas fa-pills text-primary"></i> Prescribed Medicines:</strong>
          <div class="medicine-tags">
            <% v.medicines.forEach(med => { %>
              <span class="medicine-tag">
                <%= med.name %> 
                <% if (med.dosage) { %><small>(<%= med.dosage %>)</small><% } %>
                <span class="qty">x<%= med.quantity %></span>
              </span>
            <% }) %>
          </div>
        </div>
      <% } %>

      <% if(v.nextVisit){ %>
        <small class="text-muted">
          Next Visit: <%= new Date(v.nextVisit).toDateString() %>
        </small>
      <% } %>

    </div>

  <% }) %>
</div>
<style>
    .patient-header {
  display: flex;
  justify-content: space-between;
  background: white;
  padding: 20px;
  border-radius: 12px;
  margin-bottom: 20px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.05);
}

.patient-header .left {
  display: flex;
  gap: 15px;
  align-items: center;
}

.avatar {
  width: 60px;
  height: 60px;
  background: #0d6efd;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  font-weight: bold;
}

.action-bar {
  display: flex;
  gap: 10px;
  margin-bottom: 20px;
}

.visit-section {
  background: white;
  padding: 20px;
  border-radius: 12px;
}

.visit-card {
  border-left: 4px solid #0d6efd;
  padding: 12px 15px;
  margin-bottom: 15px;
  background: #f8fafc;
  border-radius: 8px;
}

.visit-top {
  display: flex;
  justify-content: space-between;
}

.price {
  font-weight: bold;
  color: #16a34a;
}

.medicines-section {
  margin: 10px 0;
  padding: 8px 12px;
  background: #e8f4fd;
  border-radius: 8px;
}

.medicine-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 6px;
}

.medicine-tag {
  background: #0d6efd;
  color: white;
  padding: 4px 10px;
  border-radius: 15px;
  font-size: 0.85rem;
}

.medicine-tag .qty {
  background: rgba(255,255,255,0.3);
  padding: 1px 6px;
  border-radius: 10px;
  margin-left: 4px;
  font-weight: bold;
}
</style>

