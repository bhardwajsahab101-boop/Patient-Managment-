
<%- layout("./layout/boilerPlate.ejs") %>



<div class="patient-header">

  <div class="left">
    <div class="avatar">
      <%= patient.name.charAt(0).toUpperCase() %>
    </div>

    <div>
      <h2><%= patient.name %></h2>
      <p><%= patient.age %> yrs • <%= patient.gender %></p>
      <p>📞 <%= patient.phone %></p>
      <% if (patient.address) { %>
        <p>📍 <%= patient.address %></p>
      <% } %>
    </div>
  </div>

  <div class="right">
    <% 
      const today = new Date(); today.setHours(0,0,0,0);
      const next = patient.nextVisit ? new Date(patient.nextVisit) : null;
      if(next) next.setHours(0,0,0,0);
    %>

    <% if(!next){ %>
      <span class="badge bg-secondary">No Visit</span>
    <% } else if(next < today){ %>
      <span class="badge bg-danger">Overdue</span>
    <% } else if(next.getTime() === today.getTime()){ %>
      <span class="badge bg-warning text-dark">Today</span>
    <% } else { %>
      <span class="badge bg-success">Upcoming</span>
    <% } %>

    <p class="mt-2">
      Next Visit: 
      <strong>
        <%= next ? next.toDateString() : "Not Scheduled" %>
      </strong>
    </p>
  </div>

</div>

<div class="action-bar btn-action-bar">
  <a href="/patients/<%= patient._id %>/visits/new" class="btn btn-action btn-primary-action">
    <i class="fas fa-plus-circle"></i> Add Visit
  </a>
  <a href="/message/<%= patient._id %>" class="btn btn-action btn-whatsapp-action">
    <i class="fab fa-whatsapp"></i> WhatsApp
  </a>
  <a href="/patients/<%= patient._id %>/edit" class="btn btn-action btn-edit-action">
    <i class="fas fa-edit"></i> Edit
  </a>
  <a href="/patients/<%= patient._id %>/delete" class="btn btn-action btn-delete-action">
    <i class="fas fa-trash-alt"></i> Delete
  </a>
  <a href="/patients" class="btn btn-action btn-back-action">
    <i class="fas fa-arrow-left"></i> Back
  </a>
</div>

<div class="visit-section">
  <h4>Visit History</h4>

  <% if (!patient.visits.length) { %>
    <p class="text-muted">No visits yet</p>
  <% } %>

  <% patient.visits.slice().reverse().forEach((v, visitIndex) => { %>

    <div class="visit-card">

      <div class="visit-top">
        <strong><%= new Date(v.date).toDateString() %> (Visit #<%= visitIndex + 1 %>)</strong>
        <span class="price">₹<%= v.price || 0 %></span>
      </div>

      <p class="notes">
        <%= v.notes || "No notes added" %>
      </p>

      <% if (v.medicines && v.medicines.length > 0) { %>
        <div class="medicines-section">
          <strong><i class="fas fa-pills text-primary"></i> Prescribed Medicines:</strong>
          <div class="medicine-tags">
            <% v.medicines.forEach(med => { %>
              <span class="medicine-tag">
                <%= med.name %> 
                <% if (med.dosage) { %><small>(<%= med.dosage %>)</small><% } %>
                <span class="qty">x<%= med.quantity %></span>
              </span>
            <% }) %>
          </div>
        </div>
        <div class="visit-actions">
          <a href="/prescription/<%= patient._id %>/<%= visitIndex %>" 
             class="btn btn-sm btn-outline-primary" title="View Prescription">
            📋 View Prescription
          </a>
          <a  href="/prescription/<%= patient._id %>/<%= visitIndex %>?print=true" 
              
            class="btn btn-sm btn-primary" target="_blank" title="Print">
            🖨️ Print
          </a>
        </div>
      <% } else { %>
        <div class="no-medicines">No medicines prescribed this visit</div>
      <% } %>

      <% if(v.nextVisit){ %>
        <small class="text-muted">
          Next Visit: <%= new Date(v.nextVisit).toDateString() %>
        </small>
      <% } %>

    </div>

  <% }) %>
</div>
<style>
    .patient-header {
  display: flex;
  justify-content: space-between;
  background: white;
  padding: 20px;
  border-radius: 12px;
  margin-bottom: 20px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.05);
}

.patient-header .left {
  display: flex;
  gap: 15px;
  align-items: center;
}

.avatar {
  width: 60px;
  height: 60px;
  background: #0d6efd;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  font-weight: bold;
}

/* === Beautiful Action Bar Styles === */
.btn-action-bar {
  display: flex;
  gap: 12px;
  margin-bottom: 20px;
  flex-wrap: wrap;
  justify-content: flex-start;
}

.btn-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px 24px;
  border-radius: 12px;
  font-weight: 600;
  font-size: 0.95rem;
  text-decoration: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.1);
  border: none;
  cursor: pointer;
}

.btn-action i {
  font-size: 1rem;
}

/* Primary - Add Visit */
.btn-primary-action {
  background: linear-gradient(135deg, #0d6efd, #0b5ed7);
  color: white;
}
.btn-primary-action:hover {
  background: linear-gradient(135deg, #0b5ed7, #0954c4);
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(13, 110, 253, 0.35);
}

/* WhatsApp */
.btn-whatsapp-action {
  background: linear-gradient(135deg, #25D366, #128C7E);
  color: white;
}
.btn-whatsapp-action:hover {
  background: linear-gradient(135deg, #128C7E, #075e54);
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(37, 211, 102, 0.35);
}

/* Edit */
.btn-edit-action {
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  color: #1e293b;
}
.btn-edit-action:hover {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(251, 191, 36, 0.4);
}

/* Delete */
.btn-delete-action {
  background: linear-gradient(135deg, #ef4444, #dc2626);
  color: white;
}
.btn-delete-action:hover {
  background: linear-gradient(135deg, #dc2626, #b91c1c);
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(239, 68, 68, 0.4);
}

/* Back */
.btn-back-action {
  background: white;
  color: #475569;
  border: 2px solid #e2e8f0;
}
.btn-back-action:hover {
  background: #f8fafc;
  border-color: #cbd5e1;
  color: #1e293b;
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
}

/* Visit Actions */
.visit-actions {
  display: flex;
  gap: 10px;
  margin-top: 12px;
  flex-wrap: wrap;
}

.visit-actions .btn {
  padding: 8px 16px;
  border-radius: 8px;
  font-weight: 500;
  font-size: 0.85rem;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

/* Mobile responsive */
@media (max-width: 576px) {
  .btn-action-bar {
    flex-direction: column;
    width: 100%;
  }
  .btn-action {
    width: 100%;
    text-align: center;
    margin-bottom: 0.5rem;
  }
  .btn-action-bar .btn-action:last-child {
    margin-bottom: 0;
  }
}

.visit-section {
  background: white;
  padding: 20px;
  border-radius: 12px;
}

.visit-card {
  border-left: 4px solid #0d6efd;
  padding: 12px 15px;
  margin-bottom: 15px;
  background: #f8fafc;
  border-radius: 8px;
}

.visit-top {
  display: flex;
  justify-content: space-between;
}

.price {
  font-weight: bold;
  color: #16a34a;
}

.medicines-section {
  margin: 10px 0;
  padding: 8px 12px;
  background: #e8f4fd;
  border-radius: 8px;
}

.medicine-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 6px;
}

.medicine-tag {
  background: #0d6efd;
  color: white;
  padding: 4px 10px;
  border-radius: 15px;
  font-size: 0.85rem;
}

.medicine-tag .qty {
  background: rgba(255,255,255,0.3);
  padding: 1px 6px;
  border-radius: 10px;
  margin-left: 4px;
  font-weight: bold;
}
</style>

