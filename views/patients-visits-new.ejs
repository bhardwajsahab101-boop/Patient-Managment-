<%- layout("./layout/boilerPlate.ejs") %>

<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow">
        <div class="card-header bg-primary text-white">
          <h4 class="mb-0">➕ Add Visit for <%= patient.name %></h4>
          <small class="text-white-50">
            <%= patient.phone %> • Age: <%= patient.age %>
          </small>
        </div>

        <form
          method="POST"
          action="/patients/<%= patient._id %>/visits?_method=POST"
        >
          <div class="card-body">
            <div class="mb-3">
              <label for="visit-notes" class="form-label">Visit Notes</label>
              <textarea
                class="form-control"
                id="visit-notes"
                name="visit[notes]"
                rows="3"
                placeholder="Treatment details, diagnosis, medications..."
                required
              ></textarea>
            </div>

<div class="row">
 

              <div class="col-md-4 mb-3">
                <label for="visit-totalPayment" class="form-label">Visit Charge (₹)</label>
                <input
                  type="number"
                  class="form-control"
                  id="visit-totalPayment"
                  name="visit[totalPayment]"
                  min="0"
                  step="0.01"
                  placeholder="0"
                />
              </div>

              <div class="col-md-4 mb-3">
                <label for="visit-paidPayment" class="form-label">Paid for this Visit (₹)</label>
                <input
                  type="number"
                  class="form-control"
                  id="visit-paidPayment"
                  name="visit[paidPayment]"
                  min="0"
                  step="0.01"
                  placeholder="0"
                />
              </div>
            </div>

            <!-- Payment Summary Display -->
            <div class="row mb-3">
              <div class="col-md-12">
                <div class="alert alert-info mb-0 py-2">
                  <strong>Pending Amount:</strong> ₹<span id="pendingAmount">0.00</span>
                  <small class="text-muted ms-2">(Auto-calculated: Total - Paid)</small>
                </div>
              </div>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <label for="visit-nextVisit" class="form-label"
                  >Next Visit</label
                >
                <input
                  type="date"
                  class="form-control"
                  id="visit-nextVisit"
                  name="visit[nextVisit]"
                />
              </div>
            </div>

            <!-- MEDICINES -->
            <h5 class="text-primary mb-3 mt-2">💊 Prescribe Medicines <small class="text-muted">(Optional)</small></h5>
            
            <% if (typeof medicines !== 'undefined' && medicines.length > 0) { %>
              <div class="table-responsive">
                <table class="table table-sm table-bordered">
                  <thead class="table-light">
                    <tr>
                      <th style="width: 40px;">Select</th>
                      <th>Medicine</th>
                      <th>Category</th>
                      <th>Dosage</th>
                      <th>Stock</th>
                      <th style="width: 100px;">Qty</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% medicines.forEach((med, idx) => { %>
                      <tr>
                        <td class="text-center">
                        <input type="checkbox" name="medicineIds[]" value="<%= med._id %>" class="form-check-input med-check" data-index="<%= idx %>">
                        </td>
                        <td><strong><%= med.name %></strong></td>
                        <td><span class="badge bg-info text-dark"><%= med.category || 'Tablet' %></span></td>
                        <td><%= med.dosage || '-' %></td>
                        <td>
                          <input type="text" name="medicineDurations[]" class="form-control form-control-sm duration-input" placeholder="Duration" maxlength="20" disabled style="width:80px;">
                        </td>
                        <td>
                          <input type="text" name="medicineInstructions[]" class="form-control form-control-sm instructions-input" placeholder="Instructions" disabled style="width:120px;">
                        </td>
                        <td>
                          <% if (med.stock <= 5) { %>
                            <span class="badge bg-danger"><%= med.stock %></span>
                          <% } else { %>
                            <span class="badge bg-success"><%= med.stock %></span>
                          <% } %>
                        </td>
                        <td>
                          <input type="number" name="medicineQuantities[]" class="form-control form-control-sm" min="1" max="<%= med.stock %>" value="1" disabled id="qty-<%= idx %>">
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle"></i> No medicines available in stock. <a href="/medicines/new">Add medicines first</a>.
              </div>
            <% } %>
          </div>

          <div class="card-footer bg-light">
            <div class="d-flex gap-2 justify-content-between">
              <a
                href="/patient/<%= patient._id %>"
                class="btn btn-outline-secondary"
              >
                ← Back to Patient
              </a>
              <button type="submit" class="btn btn-primary">Save Visit</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
  .card {
    border: none;
    border-radius: 15px;
  }
  .card-header {
    border-radius: 15px 15px 0 0 !important;
  }
  textarea.form-control {
    resize: vertical;
  }
</style>

<script>
  // Enable/disable quantity inputs based on checkbox
  document.querySelectorAll('.med-check').forEach(checkbox => {
    checkbox.addEventListener('change', function() {
      const idx = this.dataset.index;
      const qtyInput = document.getElementById('qty-' + idx);
      qtyInput.disabled = !this.checked;
      if (this.checked) qtyInput.focus();
    });
  });

  // Auto-calculate pending amount
  const totalInput = document.getElementById('visit-totalPayment');
  const paidInput = document.getElementById('visit-paidPayment');
  const pendingSpan = document.getElementById('pendingAmount');

  function calculatePending() {
    const total = parseFloat(totalInput.value) || 0;
    let paid = parseFloat(paidInput.value);
    // If paid is empty or not provided, auto-fill with total
    if (isNaN(paid) || paidInput.value === '') {
      paid = total;
      paidInput.value = total > 0 ? total : '';
    }
    const pending = Math.max(0, total - paid);
    pendingSpan.textContent = pending.toFixed(2);
  }

  if (totalInput && paidInput) {
    totalInput.addEventListener('input', calculatePending);
    paidInput.addEventListener('input', calculatePending);
    // Initialize on page load
    calculatePending();
  }
</script>

