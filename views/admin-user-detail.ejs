<%- layout("./layout/boilerPlate.ejs") %>

<style>
  .back-link {
    margin-bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #0d6efd;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.5rem 0;
    transition: color 0.2s;
  }
  .back-link:hover {
    color: #0a58ca;
    text-decoration: none;
  }
  .back-link i {
    transition: transform 0.2s;
  }
  .back-link:hover i {
    transform: translateX(-3px);
  }
  .detail-card {
    background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
    border-radius: 16px;
    padding: 1.75rem;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08), 0 1px 3px rgba(0,0,0,0.04);
    margin-bottom: 1.5rem;
    transition: all 0.3s ease;
    border-left: 4px solid #fd7e14;
    position: relative;
    overflow: hidden;
  }
  .detail-card::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 100px;
    height: 100px;
    background: radial-gradient(circle, rgba(253,126,20,0.06) 0%, transparent 70%);
    border-radius: 50%;
    transform: translate(30%, -30%);
  }
  .detail-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.12);
  }
  .detail-card h5 {
    margin-bottom: 1.25rem;
    font-weight: 700;
    color: #1a1a2e;
    border-bottom: 2px solid #e9ecef;
    padding-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .detail-card h5 i {
    color: #fd7e14;
  }
  .detail-row {
    display: flex;
    justify-content: space-between;
    padding: 0.6rem 0;
    border-bottom: 1px solid #f1f3f5;
    position: relative;
    z-index: 1;
  }
  .detail-row:last-child {
    border-bottom: none;
  }
  .detail-label {
    font-weight: 500;
    color: #6c757d;
  }
  .detail-value {
    font-weight: 600;
    color: #212529;
  }
  .badge-status {
    font-size: 0.8rem;
    padding: 0.35em 0.65em;
    border-radius: 6px;
  }
  .badge-active {
    background: #d1fae5;
    color: #065f46;
  }
  .badge-inactive {
    background: #fee2e2;
    color: #991b1b;
  }
  .badge-expired {
    background: #fef3c7;
    color: #92400e;
  }
  .actions-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .sub-form {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .sub-form input {
    width: 80px;
    padding: 0.35rem 0.5rem;
    border: 1px solid #ced4da;
    border-radius: 6px;
    font-size: 0.875rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .actions-bar {
      flex-direction: column;
      align-items: stretch;
      gap: 0.6rem;
    }
    .actions-bar form,
    .actions-bar .sub-form,
    .actions-bar .btn {
      width: 100%;
    }
    .sub-form {
      justify-content: space-between;
    }
    .sub-form input {
      flex: 1;
      width: auto;
    }
    .detail-card {
      padding: 1.25rem;
    }
    .detail-row {
      flex-direction: column;
      gap: 0.2rem;
      padding: 0.6rem 0;
    }
    .detail-label {
      font-size: 0.85rem;
    }
    .detail-value {
      font-size: 0.95rem;
    }
  }

  @media (max-width: 480px) {
    .detail-card {
      padding: 1.1rem;
      border-radius: 12px;
    }
    .actions-bar .btn {
      font-size: 0.85rem;
      padding: 0.4rem 0.75rem;
    }
  }
</style>

<a href="/admin" class="back-link">
  <i class="fa-solid fa-arrow-left"></i>Back to Admin Panel
</a>

<div class="actions-bar">
  <form action="/admin/users/<%= user._id %>/toggle" method="POST">
    <% if (user.isActive) { %>
      <button type="submit" class="btn btn-outline-danger">
        <i class="fa-solid fa-ban me-1"></i>Deactivate
      </button>
    <% } else { %>
      <button type="submit" class="btn btn-success">
        <i class="fa-solid fa-check me-1"></i>Activate
      </button>
    <% } %>
  </form>
  
  <form action="/admin/users/<%= user._id %>/subscription" method="POST" class="sub-form">
    <input type="number" name="subscriptionDays" value="30" min="1" max="3650" title="Days" />
    <button type="submit" class="btn btn-primary">
      <i class="fa-solid fa-rotate me-1"></i>Renew Subscription
    </button>
  </form>

  <form action="/admin/users/<%= user._id %>/delete" method="POST" 
        onsubmit="return confirm('Are you sure you want to delete user: <%= user.name %>? This action cannot be undone.');">
    <input type="hidden" name="deleteClinic" value="true" />
    <button type="submit" class="btn btn-danger">
      <i class="fa-solid fa-trash me-1"></i>Delete User & Clinic
    </button>
  </form>

  <form action="/admin/users/<%= user._id %>/delete" method="POST" 
        onsubmit="return confirm('Are you sure you want to delete user: <%= user.name %>? This action cannot be undone.');">
    <input type="hidden" name="deleteClinic" value="false" />
    <button type="submit" class="btn btn-outline-danger">
      <i class="fa-solid fa-trash me-1"></i>Delete User Only
    </button>
  </form>
</div>

<div class="row">
  <div class="col-lg-6">
    <div class="detail-card">
      <h5><i class="fa-solid fa-user"></i>User Information</h5>
      <div class="detail-row">
        <span class="detail-label">Name</span>
        <span class="detail-value"><%= user.name %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Phone</span>
        <span class="detail-value"><%= user.phone %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Role</span>
        <span class="detail-value">
          <% if (user.role === 'admin') { %>
            <span class="badge bg-dark">Admin</span>
          <% } else { %>
            <span class="badge bg-primary">Doctor</span>
          <% } %>
        </span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Status</span>
        <span class="detail-value">
          <% 
            const isExpired = user.subscriptionEndsAt ? new Date() > new Date(user.subscriptionEndsAt) : false;
          %>
          <% if (user.isActive && !isExpired) { %>
            <span class="badge-status badge-active"><i class="fa-solid fa-check-circle me-1"></i>Active</span>
          <% } else if (!user.isActive) { %>
            <span class="badge-status badge-inactive"><i class="fa-solid fa-clock me-1"></i>Pending Approval</span>
          <% } else { %>
            <span class="badge-status badge-expired"><i class="fa-solid fa-triangle-exclamation me-1"></i>Subscription Expired</span>
          <% } %>
        </span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Registered On</span>
        <span class="detail-value"><%= new Date(user.createdAt).toLocaleDateString() %></span>
      </div>
      <% if (user.subscriptionEndsAt) { %>
        <div class="detail-row">
          <span class="detail-label">Subscription Ends</span>
          <span class="detail-value"><%= new Date(user.subscriptionEndsAt).toLocaleDateString() %></span>
        </div>
      <% } %>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="detail-card">
      <h5><i class="fa-solid fa-hospital"></i>Registered Clinic</h5>
      <% if (clinic) { %>
        <div class="detail-row">
          <span class="detail-label">Clinic Name</span>
          <span class="detail-value"><%= clinic.name %></span>
        </div>
        <% if (clinic.location) { %>
          <div class="detail-row">
            <span class="detail-label">Location</span>
            <span class="detail-value"><%= clinic.location %></span>
          </div>
        <% } %>
        <div class="detail-row">
          <span class="detail-label">Created On</span>
          <span class="detail-value"><%= new Date(clinic.createdAt).toLocaleDateString() %></span>
        </div>
        <div class="mt-3">
          <form action="/admin/clinics/<%= clinic._id %>/delete" method="POST" 
                onsubmit="return confirm('Are you sure you want to delete clinic: <%= clinic.name %>?');">
            <button type="submit" class="btn btn-outline-danger btn-sm">
              <i class="fa-solid fa-trash me-1"></i>Delete This Clinic Only
            </button>
          </form>
        </div>
      <% } else { %>
        <div class="alert alert-warning mb-0">
          <i class="fa-solid fa-triangle-exclamation me-2"></i>This user has not registered any clinic yet.
        </div>
      <% } %>
    </div>
  </div>
</div>

