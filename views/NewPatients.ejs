<%- layout("./layout/boilerPlate.ejs") %>

<h3 class="fw-bold mb-4">Add New Patient</h3>

<div class="card p-4 shadow-sm">
  <% 
    // Define local helper variables to reduce repetitive typeof checks
    const _hasErrors = typeof errors !== 'undefined' && errors && errors.length;
    const _patient = (typeof patient !== 'undefined' && patient) ? patient : {};
    const _visit = (typeof visit !== 'undefined' && visit) ? visit : {};
    const _medicines = (typeof medicines !== 'undefined') ? medicines : [];
    
    // Handle selected medicine IDs with proper undefined checks
    let localMedIds = (typeof selectedMedicineIds !== 'undefined') ? selectedMedicineIds : [];
    const selectedIds = Array.isArray(localMedIds)
      ? localMedIds.map(String)
      : localMedIds
      ? [String(localMedIds)]
      : [];
    const quantityMap = (typeof selectedMedicineQuantities !== 'undefined') ? selectedMedicineQuantities : {};
  %>

  <% if (_hasErrors) { %>
    <div class="alert alert-danger">
      <% errors.forEach(function(e) { %>
        <div><%= e.msg %></div>
      <% }) %>
    </div>
  <% } %>

  <form action="/patients" method="POST">

    <!-- PATIENT INFO -->
    <h5 class="text-primary mb-3">🧑 Patient Information</h5>
    
    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label" for="patientName">Name *</label>
        <input type="text" id="patientName" name="patient[name]" class="form-control" required
          value="<%= _patient.name || '' %>" placeholder="Enter patient name" />
      </div>

      <div class="col-md-3 mb-3">
        <label class="form-label" for="patientAge">Age</label>
        <input type="number" id="patientAge" name="patient[age]" class="form-control" min="0" max="120"
          value="<%= _patient.age || '' %>" placeholder="Years" />
      </div>

      <div class="col-md-3 mb-3">
        <label class="form-label" for="patientGender">Gender</label>
        <select id="patientGender" name="patient[gender]" class="form-select">
          <option value="">Select gender</option>
          <option value="Male" <%= _patient.gender === 'Male' ? 'selected' : '' %>>Male</option>
          <option value="Female" <%= _patient.gender === 'Female' ? 'selected' : '' %>>Female</option>
          <option value="Other" <%= _patient.gender === 'Other' ? 'selected' : '' %>>Other</option>
        </select>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label" for="patientPhone">Phone *</label>
        <input type="tel" id="patientPhone" name="patient[phone]" class="form-control" required
          value="<%= _patient.phone || '' %>" placeholder="10-digit mobile number" pattern="[0-9]{10}" />
      </div>

      <div class="col-md-6 mb-3">
        <label class="form-label" for="patientTreatment">Treatment</label>
        <input type="text" id="patientTreatment" name="patient[treatment]" class="form-control"
          value="<%= _patient.treatment || '' %>" placeholder="Current treatment if any" />
      </div>

      <div class="col-12 mb-3">
        <label class="form-label" for="patientAddress">Address</label>
        <textarea id="patientAddress" name="patient[address]" class="form-control" rows="2"
          placeholder="Full address"><%= _patient.address || '' %></textarea>
      </div>
    </div>

<!-- VISIT & PAYMENT INFO -->
    <h5 class="text-primary mb-3 mt-4">📋 First Visit / Payment</h5>
    
    <div class="row">
      <div class="col-md-4 mb-3">
        <label class="form-label" for="visitNextVisit">Next Visit Date</label>
        <input type="date" id="visitNextVisit" name="visit[nextVisit]" class="form-control"
          value="<%= _visit.nextVisit || '' %>" />
      </div>

<div class="col-md-4 mb-3">
        <label class="form-label" for="visitPrice">Total Payment (₹)</label>
        <input type="number" id="visitPrice" name="patient[totalPayment]" class="form-control" min="0" step="0.01"
          value="<%= _patient.totalPayment || _visit.price || '' %>" placeholder="0.00" oninput="updatePending()" />
      </div>
      
      <div class="col-md-4 mb-3">
        <label class="form-label" for="paidPayment">Paid Amount (₹)</label>
        <input type="number" id="paidPayment" name="patient[paidPayment]" class="form-control" min="0" step="0.01"
          value="<%= _patient.paidPayment || '' %>" placeholder="Leave empty for full payment" oninput="updatePending()" />
      </div>
    </div>

    <!-- Pending Display (Auto-calculated) -->
    <div class="row">
      <div class="col-md-4 mb-3">
        <label class="form-label" for="pendingPayment">Pending Amount (₹)</label>
        <input type="text" id="pendingPayment" class="form-control" readonly 
          value="<%= typeof _patient.pendingPayment !== 'undefined' ? _patient.pendingPayment : '0.00' %>" 
          placeholder="Auto-calculated" />
      </div>
      <div class="col-md-8 mb-3 d-flex align-items-end">
        <div class="alert alert-info mb-0 w-100">
          <i class="fas fa-info-circle me-1"></i> 
          <strong>Pending = Total Payment - Paid Amount</strong>
        </div>
      </div>
    </div>

    <div class="mb-3">
      <label class="form-label" for="visitNotes">Notes</label>
      <textarea id="visitNotes" name="visit[notes]" class="form-control" rows="2"
        placeholder="Visit notes or symptoms"><%= _visit.notes || '' %></textarea>
    </div>

    <!-- MEDICINES -->
    <h5 class="text-primary mb-3 mt-4">💊 Prescribe Medicines <small class="text-muted">(Optional)</small></h5>
    
    <% if (_medicines.length > 0) { %>
      <div class="table-responsive">
        <table class="table table-sm table-bordered">
          <thead class="table-light">
            <tr>
              <th style="width: 40px;">Select</th>
              <th>Medicine</th>
              <th>Category</th>
              <th>Dosage</th>
              <th>Stock</th>
              <th style="width: 100px;">Qty</th>
            </tr>
          </thead>
          <tbody>
            <% _medicines.forEach((med, idx) => { %>
              <tr>
                <td class="text-center">
                  <% const isSelected = selectedIds.includes(String(med._id)); %>
                  <input type="checkbox" name="medicineIds[]" value="<%= med._id %>" 
                    class="form-check-input med-check" data-index="<%= idx %>" <%= isSelected ? 'checked' : '' %>
                    id="medCheck<%= idx %>">
                </td>
                <td>
                  <label for="medCheck<%= idx %>"><strong><%= med.name %></strong></label>
                </td>
                <td><span class="badge bg-info text-dark"><%= med.category || 'Tablet' %></span></td>
                <td><%= med.dosage || '-' %></td>
                <td>
                  <% if (med.stock <= 5) { %>
                    <span class="badge bg-danger" title="Low stock"><%= med.stock %></span>
                  <% } else { %>
                    <span class="badge bg-success"><%= med.stock %></span>
                  <% } %>
                </td>
                <td>
                  <% const selectedQty = quantityMap[String(med._id)] || "1"; %>
                  <input type="number" name="medicineQuantities[]" 
                    class="form-control form-control-sm" min="1" max="<%= med.stock %>" 
                    value="<%= selectedQty %>" <%= selectedIds.includes(String(med._id)) ? '' : 'disabled' %>
                    id="qty-<%= idx %>">
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle"></i> No medicines available in stock. <a href="/medicines/new">Add medicines first</a>.
      </div>
    <% } %>

    <div class="d-flex gap-2 mt-4">
      <button type="submit" class="btn btn-primary">Save Patient</button>
      <a href="/patients" class="btn btn-outline-secondary">Cancel</a>
    </div>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Enable/disable quantity inputs based on checkbox
    document.querySelectorAll('.med-check').forEach(function(checkbox) {
      checkbox.addEventListener('change', function() {
        var idx = this.dataset.index;
        var qtyInput = document.getElementById('qty-' + idx);
        if (qtyInput) {
          qtyInput.disabled = !this.checked;
          if (this.checked) qtyInput.focus();
        }
      });
    });
    
    // Initialize pending calculation
    updatePending();
  });
  
  // Simple function: Pending = Total - Paid (empty paid = fully paid)
  function updatePending() {
    var total = parseFloat(document.getElementById('visitPrice')?.value) || 0;
    var paidInput = document.getElementById('paidPayment');
    var paid = paidInput.value;
    // If paid is empty, default to total (fully paid)
    if (paid === '' || paid === null || isNaN(parseFloat(paid))) {
      paid = total;
      paidInput.value = '';
    } else {
      paid = parseFloat(paid);
    }
    var pending = Math.max(0, total - paid);
    document.getElementById('pendingPayment').value = pending.toFixed(2);
  }
</script>

