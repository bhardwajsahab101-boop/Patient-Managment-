<%- layout("./layout/boilerPlate.ejs") %>

<h3 class="fw-bold mb-4">Add New Patient</h3>

<div class="card p-4 shadow-sm">
  <% if (typeof errors !== 'undefined' && errors && errors.length) { %>
    <div class="alert alert-danger">
      <% errors.forEach(function(e) { %>
        <div><%= e.msg %></div>
      <% }) %>
    </div>
  <% } %>

  <form action="/patients" method="POST">

    <!-- PATIENT INFO -->
    <h5 class="text-primary mb-3">🧑 Patient Information</h5>
    
    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label">Name *</label>
        <input type="text" name="patient[name]" class="form-control" required
          value="<%= (typeof patient !== 'undefined' && patient) ? patient.name : '' %>" />
      </div>

      <div class="col-md-3 mb-3">
        <label class="form-label">Age</label>
        <input type="number" name="patient[age]" class="form-control"
          value="<%= (typeof patient !== 'undefined' && patient) ? patient.age : '' %>" />
      </div>

      <div class="col-md-3 mb-3">
        <label class="form-label">Gender</label>
        <select name="patient[gender]" class="form-select">
          <option value="Male" <%= (typeof patient !== 'undefined' && patient && patient.gender === 'Male') ? 'selected' : '' %>>Male</option>
          <option value="Female" <%= (typeof patient !== 'undefined' && patient && patient.gender === 'Female') ? 'selected' : '' %>>Female</option>
          <option value="Other" <%= (typeof patient !== 'undefined' && patient && patient.gender === 'Other') ? 'selected' : '' %>>Other</option>
        </select>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label">Phone *</label>
        <input type="text" name="patient[phone]" class="form-control" required
          value="<%= (typeof patient !== 'undefined' && patient) ? patient.phone : '' %>" />
      </div>

      <div class="col-md-6 mb-3">
        <label class="form-label">Treatment</label>
        <input type="text" name="patient[treatment]" class="form-control"
          value="<%= (typeof patient !== 'undefined' && patient) ? patient.treatment : '' %>" />
      </div>
    </div>

    <!-- VISIT INFO -->
    <h5 class="text-primary mb-3 mt-4">📋 First Visit</h5>
    
    <div class="row">
      <div class="col-md-4 mb-3">
        <label class="form-label">Next Visit Date</label>
        <input type="date" name="visit[nextVisit]" class="form-control"
          value="<%= (typeof visit !== 'undefined' && visit) ? visit.nextVisit : '' %>" />
      </div>

      <div class="col-md-4 mb-3">
        <label class="form-label">Price (₹)</label>
        <input type="number" name="visit[price]" class="form-control" min="0" step="0.01"
          value="<%= (typeof visit !== 'undefined' && visit) ? visit.price : '' %>" />
      </div>
    </div>

    <div class="mb-3">
      <label class="form-label">Notes</label>
      <textarea name="visit[notes]" class="form-control" rows="2"><%= (typeof visit !== 'undefined' && visit) ? visit.notes : '' %></textarea>
    </div>

    <!-- MEDICINES -->
    <h5 class="text-primary mb-3 mt-4">💊 Prescribe Medicines <small class="text-muted">(Optional)</small></h5>
    
    <% if (typeof medicines !== 'undefined' && medicines.length > 0) { %>
      <div class="table-responsive">
        <table class="table table-sm table-bordered">
          <thead class="table-light">
            <tr>
              <th style="width: 40px;">Select</th>
              <th>Medicine</th>
              <th>Category</th>
              <th>Dosage</th>
              <th>Stock</th>
              <th style="width: 100px;">Qty</th>
            </tr>
          </thead>
          <tbody>
            <% medicines.forEach((med, idx) => { %>
              <tr>
                <td class="text-center">
                  <input type="checkbox" name="medicineIds[]" value="<%= med._id %>" class="form-check-input med-check" data-index="<%= idx %>">
                </td>
                <td><strong><%= med.name %></strong></td>
                <td><span class="badge bg-info text-dark"><%= med.category || 'Tablet' %></span></td>
                <td><%= med.dosage || '-' %></td>
                <td>
                  <% if (med.stock <= 5) { %>
                    <span class="badge bg-danger"><%= med.stock %></span>
                  <% } else { %>
                    <span class="badge bg-success"><%= med.stock %></span>
                  <% } %>
                </td>
                <td>
                  <input type="number" name="medicineQuantities[]" class="form-control form-control-sm" min="1" max="<%= med.stock %>" value="1" disabled id="qty-<%= idx %>">
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle"></i> No medicines available in stock. <a href="/medicines/new">Add medicines first</a>.
      </div>
    <% } %>

    <div class="d-flex gap-2 mt-4">
      <button class="btn btn-primary">Save Patient</button>
      <a href="/patients" class="btn btn-outline-secondary">Cancel</a>
    </div>
  </form>
</div>

<script>
  // Enable/disable quantity inputs based on checkbox
  document.querySelectorAll('.med-check').forEach(checkbox => {
    checkbox.addEventListener('change', function() {
      const idx = this.dataset.index;
      const qtyInput = document.getElementById('qty-' + idx);
      qtyInput.disabled = !this.checked;
      if (this.checked) qtyInput.focus();
    });
  });
</script>

