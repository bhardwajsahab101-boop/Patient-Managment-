<aside class="sidebar" id="sidebar">
  <div class="logo">
    <h3>Patient Care Management System</h3>
  </div>

<a class="<%= currentRoute === '/' ? 'active' : '' %>" href="/dashboard"
    ><i class="fas fa-tachometer-alt me-2"></i>Dashboard</a>

  <a
    class="<%= currentRoute === '/profile' ? 'active' : '' %>"
    href="/profile"
    ><i class="fa-solid fa-id-card me-2"></i>My Profile</a>

  <a
    class="<%= currentRoute.startsWith('/patients') ? 'active' : '' %>"
    href="/patients"
    ><i class="fas fa-user-injured me-2"></i>Patients</a>

  <a
    class="<%= currentRoute.startsWith('/followup') ? 'active' : '' %>"
    href="/followup"
    ><i class="fas fa-calendar-check me-2"></i>Follow-ups</a>

  <a
    class="<%= currentRoute.startsWith('/reports') ? 'active' : '' %>"
    href="/reports"
    ><i class="fas fa-chart-bar me-2"></i>Reports</a>

  <a
    class="<%= currentRoute.startsWith('/medicines') ? 'active' : '' %>"
    href="/medicines"
    ><i class="fas fa-pills me-2"></i>Medicines</a>

  <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'admin') { %>
  <a
    class="<%= currentRoute === '/admin' ? 'active' : '' %>"
    href="/admin"
    ><i class="fa-solid fa-shield-halved me-2"></i>Admin Panel</a>
  <a
    class="<%= currentRoute.startsWith('/admin/clinics') ? 'active' : '' %>"
    href="/admin/clinics"
    ><i class="fa-solid fa-hospital me-2"></i>Clinics</a>
  <% } %>

  <section class="bottom">
    <p>Need Help? Quick support and help</p>
    <a
      href="https://wa.me/918950817515"
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-success btn-sm w-100 mb-2"
    >
      <i class="fab fa-whatsapp me-1"></i>Chat on WhatsApp
    </a>
    <a href="/support" class="btn btn-outline-light btn-sm w-100">
      <i class="fas fa-envelope me-1"></i>Send Message
    </a>
  </section>
</aside>

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const sidebar = document.getElementById("sidebar");
    const overlay = document.getElementById("sidebarOverlay");

    const toggles = document.querySelectorAll(".sidebar-toggle");
    toggles.forEach(function (toggle) {
      toggle.addEventListener("click", function () {
        const icon = this.querySelector(".toggle-icon");
        const isDesktop = window.innerWidth >= 993;
        if (isDesktop) {
          sidebar.classList.toggle("hidden");
          document.body.classList.toggle("sidebar-hidden");
        } else {
          sidebar.classList.toggle("show");
          overlay.classList.toggle("show");
        }
        if (icon) {
          icon.classList.toggle("fa-bars");
          icon.classList.toggle("fa-xmark");
        }
      });
    });

    if (overlay) {
      overlay.addEventListener("click", function () {
        sidebar.classList.remove("show");
        overlay.classList.remove("show");
      });
    }

    document.querySelectorAll(".sidebar a").forEach((link) => {
      link.addEventListener("click", () => {
        if (window.innerWidth <= 992) {
          sidebar.classList.remove("show");
          overlay.classList.remove("show");
        } else if (sidebar.classList.contains("hidden")) {
          sidebar.classList.remove("hidden");
          document.body.classList.remove("sidebar-hidden");
        }
      });
    });
  });
</script>
