<% title = 'Support' %>

<%- layout("./layout/boilerPlate.ejs") %>

<div class="container mt-5 mb-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      
      <!-- Header -->
      <div class="text-center mb-4">
        <div class="support-icon mb-3">💬</div>
        <h2 class="fw-bold">Need Help?</h2>
        <p class="text-muted">We're here to assist you. Choose the fastest way to reach us.</p>
      </div>

      <!-- Success Alert -->
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <i class="fas fa-check-circle me-2"></i><%= success %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>

      <!-- Error Alert -->
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <i class="fas fa-exclamation-circle me-2"></i><%= error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>

      <!-- WhatsApp Card: Main CTA -->
      <div class="card shadow-sm border-success mb-4">
        <div class="card-body text-center p-4">
          <h5 class="card-title mb-3">
            <i class="fab fa-whatsapp text-success fa-lg me-2"></i>Chat on WhatsApp
          </h5>
          <p class="text-muted mb-3">
            Get instant help via WhatsApp. Tap the button below to start a chat.
          </p>
          <a 
            href="https://wa.me/<%= supportNumber %>" 
            target="_blank" 
            rel="noopener noreferrer"
            class="btn btn-success btn-lg w-100"
          >
            <i class="fab fa-whatsapp me-2"></i>Contact Support on WhatsApp
          </a>
          <small class="text-muted d-block mt-2">
            <i class="fas fa-bolt text-warning me-1"></i>Fastest response time
          </small>
        </div>

      <!-- Divider -->
      <div class="d-flex align-items-center my-4">
        <div class="flex-grow-1 border-top"></div>
        <span class="mx-3 text-muted text-uppercase small fw-semibold">or</span>
        <div class="flex-grow-1 border-top"></div>

      <!-- Support Form Card: Fallback -->
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h5 class="mb-0">
            <i class="fas fa-envelope me-2 text-primary"></i>Send a Message
          </h5>
          <small class="text-muted">Describe your issue and we'll get back to you.</small>
        </div>
        <div class="card-body">
          <form action="/support" method="POST" novalidate>
            <div class="mb-3">
              <label for="subject" class="form-label fw-semibold">Subject</label>
              <input 
                type="text" 
                class="form-control" 
                id="subject" 
                name="subject" 
                placeholder="e.g., Login issue, Feature request..."
                value="<%= typeof formData !== 'undefined' && formData.subject ? formData.subject : '' %>"
                maxlength="200"
                required
              >
            </div>
            <div class="mb-3">
              <label for="message" class="form-label fw-semibold">Message</label>
              <textarea 
                class="form-control" 
                id="message" 
                name="message" 
                rows="5" 
                placeholder="Describe your issue in detail..."
                maxlength="2000"
                required
              ><%= typeof formData !== 'undefined' && formData.message ? formData.message : '' %></textarea>
              <div class="form-text text-end">
                <span id="charCount">0</span> / 2000
              </div>
            <div class="d-grid">
              <button type="submit" class="btn btn-primary">
                <i class="fas fa-paper-plane me-2"></i>Send Message
              </button>
            </div>
          </form>
        </div>

      <!-- Past Messages -->
      <% if (typeof pastMessages !== 'undefined' && pastMessages.length > 0) { %>
        <div class="mt-5">
          <h5 class="fw-bold mb-3">
            <i class="fas fa-history me-2 text-secondary"></i>Your Past Messages
          </h5>
          <div class="list-group">
            <% pastMessages.forEach(msg => { %>
              <div class="list-group-item list-group-item-action">
                <div class="d-flex w-100 justify-content-between align-items-start">
                  <h6 class="mb-1"><%= msg.subject %></h6>
                  <span class="badge <%= msg.status === 'open' ? 'bg-warning text-dark' : 'bg-success' %>">
                    <%= msg.status === 'open' ? 'Open' : 'Resolved' %>
                  </span>
                </div>
                <p class="mb-1 text-muted small"><%= msg.message %></p>
                <small class="text-muted">
                  <i class="far fa-clock me-1"></i><%= new Date(msg.createdAt).toLocaleString() %>
                </small>
              </div>
            <% }) %>
          </div>
      <% } %>

    </div>
</div>

<script>
  // Character counter for message textarea
  const messageTextarea = document.getElementById('message');
  const charCount = document.getElementById('charCount');
  
  if (messageTextarea && charCount) {
    function updateCount() {
      charCount.textContent = messageTextarea.value.length;
    }
    messageTextarea.addEventListener('input', updateCount);
    updateCount(); // initial count
  }
</script>

<style>
  .support-icon {
    font-size: 3.5rem;
    line-height: 1;
  }
  .card {
    border-radius: 12px;
    border: none;
  }
  .card-header {
    border-radius: 12px 12px 0 0 !important;
    background: #f8f9fa;
  }
  .btn-success {
    background-color: #25D366;
    border-color: #25D366;
  }
  .btn-success:hover {
    background-color: #128C7E;
    border-color: #128C7E;
  }
  .list-group-item {
    border-radius: 10px !important;
    margin-bottom: 8px;
    border: 1px solid rgba(0,0,0,0.05);
  }
</style>
