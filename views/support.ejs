                <div class="timeline-item">
                  <div class="step-card p-4 mb-3">
                    <h6>2. Schedule New Follow-up</h6>
                    <p>Select patient, set date/time, add notes.</p>
                  </div>
                </div>
                <div class="timeline-item">
                  <div class="step-card p-4">
                    <h6>3. Track & Complete</h6>
                    <p>Mark as completed or reschedule as needed.</p>
                  </div>
                </div>
              </div>
            </section>

            <!-- Reports Section -->
            <section id="reports" class="mb-5">
              <h3 class="mb-4">How to Generate Reports</h3>
              <div class="row g-3">
                <div class="col-lg-4">
                  <div class="step-card p-4">
                    <h6>1. Access Reports</h6>
                    <p>Click <strong>Reports</strong> from sidebar.</p>
                  </div>
                </div>
                <div class="col-lg-4">
                  <div class="step-card p-4">
                    <h6>2. Select Report Type</h6>
                    <p>Patient stats, prescription summary, stock report.</p>
                  </div>
                </div>
                <div class="col-lg-4">
                  <div class="step-card p-4">
                    <h6>3. Filter & Export</h6>
                    <p>Apply date range, export to PDF/Excel.</p>
                  </div>
                </div>
              </div>
            </section>

            <!-- Stock Management Section -->
            <section id="stock" class="mb-5">
              <h3 class="mb-4">Stock Management</h3>
              <div class="timeline">
                <div class="timeline-item">
                  <div class="step-card p-4 mb-3">
                    <h6>1. View Inventory</h6>
