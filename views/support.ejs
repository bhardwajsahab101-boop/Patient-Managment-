          <div class="col-lg-9">
            <!-- Dashboard Section -->
            <section id="dashboard" class="mb-5">
              <h3 class="mb-4">Dashboard Overview</h3>
              <div class="timeline">
                <div class="timeline-item">
                  <div class="step-card p-4 mb-3">
                    <h6>1. Access Dashboard</h6>
                    <p>
                      Click <strong>Dashboard</strong> from sidebar to view
                      clinic stats, recent patients, upcoming appointments, and
                      quick actions.
                    </p>
                    <img
                      src="/image/dashboard.jpeg"
                      alt="Dashboard"
                      class="img-fluid rounded shadow-sm w-100 clickable-image"
                      style="height: 200px; object-fit: cover"
                      onclick="openImageViewer(this)"
                    />
                  </div>
                </div>
                <div class="timeline-item">
                  <div class="step-card p-4">
                    <h6>2. Quick Stats & Actions</h6>
                    <p>
                      Monitor today's patients, low stock alerts, and recent
                      prescriptions.
                    </p>
                  </div>
                </div>
              </div>
            </section>

            <!-- Step-by-Step Guides -->
            <section id="add-patient" class="mb-5">
              <h3 class="mb-4">How to Manage Patients (Add, View, Visits)</h3>
              <div class="timeline">
                <div class="timeline-item">
                  <div class="step-card p-4 mb-3">
                    <h6>1. Open Dashboard</h6>
                    <p>
                      Click <strong>Patients</strong> in sidebar →
                      <strong>New Patient</strong>
                    </p>
                    <img
                      src="/image/dashboard.jpeg"
                      alt="Patient Dashboard"
                      class="img-fluid rounded shadow-sm w-100 clickable-image"
                      style="height: 200px; object-fit: cover"
                      onclick="openImageViewer(this)"
                    />
                  </div>
                </div>
                <div class="timeline-item">
                  <div class="step-card p-4 mb-3">
                    <h6>2. Fill Patient Details</h6>
                    <p>Enter name, phone, age, and medical history</p>
                    <img
                      src="/image/Patient_form.jpeg"
                      alt="Patient Form"
                      class="img-fluid rounded shadow-sm w-100 clickable-image"
                      style="height: 200px; object-fit: cover"
                      onclick="openImageViewer(this)"
                    />
                  </div>
                </div>
                <div class="timeline-item">
                  <div class="step-card p-4">
                    <h6>3. Save Patient</h6>
                    <p>
                      Click <strong>Save Patient</strong> → Patient added
                      successfully!
                    </p>
                  </div>
                </div>
              </div>
            </section>

            <section id="medicines" class="mb-5">
              <h3 class="mb-4">How to Add Medicines</h3>
              <div class="timeline">
                <div class="timeline-item">
                  <div class="step-card p-4 mb-3">
                    <h6>1. Medicines Inventory</h6>
                    <p>Navigate to <strong>Medicines</strong> section</p>
                    <img
                      src="/image/Medicines.jpeg"
                      alt="Medicines Page"
                      class="img-fluid rounded shadow-sm w-100 clickable-image"
                      style="height: 200px; object-fit: cover"
                      onclick="openImageViewer(this)"
                    />
                  </div>
                </div>
                <div class="timeline-item">
                  <div class="step-card p-4 mb-3">
                    <h6>2. Add New Medicine</h6>
                    <p>Fill medicine name, stock quantity, expiry date</p>
                  </div>
                </div>
                <div class="timeline-item">
                  <div class="step-card p-4">
                    <h6>3. Save Medicine</h6>
                    <p>Click save to add to inventory</p>
                  </div>
                </div>
              </div>
            </section>

            <section id="notifications" class="mb-5">
              <h3 class="mb-4">How to Send Notifications</h3>
              <div class="row g-3">
                <div class="col-md-4">
                  <div class="step-card p-4 text-center">
                    <h6>1. Open Messages</h6>
                    <img
                      src="/image/Message.jpeg"
                      alt="Messages Screen"
                      class="img-fluid rounded shadow-sm w-100 clickable-image"
                      style="height: 200px; object-fit: cover"
                      onclick="openImageViewer(this)"
                    />
                  </div>
                </div>
