                  </div>
                </div>
                <div class="col-lg-4">
                  <div class="step-card p-4">
                    <h6>2. Add Prescription Items</h6>
                  </div>
                </div>
                <div class="col-lg-4">
                  <div class="step-card p-4">
                    <h6>3. Print/Download PDF</h6>
                  </div>
                </div>
              </div>
            </section>

            <!-- Follow-up Section -->
            <section id="followup" class="mb-5">
              <h3 class="mb-4">How to Manage Follow-ups</h3>
              <div class="timeline">
