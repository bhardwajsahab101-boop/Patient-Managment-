<%- layout("./layout/boilerPlate.ejs") %>

<style>
  .admin-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .admin-header i {
    font-size: 2rem;
    color: #0d6efd;
  }
  .admin-header h2 {
    margin: 0;
    font-weight: 700;
  }
  .clinic-card {
    background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08), 0 1px 3px rgba(0,0,0,0.04);
    margin-bottom: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem;
    justify-content: space-between;
    border-left: 4px solid #20c997;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }
  .clinic-card::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 120px;
    height: 120px;
    background: radial-gradient(circle, rgba(32,201,151,0.06) 0%, transparent 70%);
    border-radius: 50%;
    transform: translate(30%, -30%);
  }
  .clinic-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.06);
  }
  .clinic-info {
    flex: 1;
    min-width: 220px;
    position: relative;
    z-index: 1;
  }
  .clinic-info h5 {
    margin: 0 0 0.5rem 0;
    font-weight: 700;
    font-size: 1.15rem;
    color: #1a1a2e;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .clinic-meta {
    font-size: 0.875rem;
    color: #6c757d;
    margin-bottom: 0.5rem;
  }
  .clinic-meta span {
    margin-right: 1rem;
    display: inline-flex;
    align-items: center;
  }
  .clinic-meta i {
    color: #20c997;
    font-size: 0.8rem;
  }
  .badge-status {
    font-size: 0.8rem;
    padding: 0.35em 0.65em;
    border-radius: 6px;
  }
  .badge-active {
    background: #d1fae5;
    color: #065f46;
  }
  .badge-inactive {
    background: #fee2e2;
    color: #991b1b;
  }
  .clinic-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }
  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .stat-card {
    background: linear-gradient(145deg, #ffffff 0%, #f0f4f8 100%);
    border-radius: 16px;
    padding: 1.5rem 1.25rem;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08), 0 1px 3px rgba(0,0,0,0.04);
    text-align: center;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(32,201,151,0.08);
  }
  .stat-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #20c997, #0dcaf0);
    border-radius: 0 0 16px 16px;
  }
  .stat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(32,201,151,0.15);
  }
  .stat-card h3 {
    margin: 0;
    font-weight: 800;
    font-size: 2rem;
    background: linear-gradient(135deg, #20c997 0%, #0dcaf0 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .stat-card p {
    margin: 0.4rem 0 0 0;
    font-size: 0.85rem;
    color: #6c757d;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .back-link {
    margin-bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #0d6efd;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.5rem 0;
    transition: color 0.2s;
  }
  .back-link:hover {
    color: #0a58ca;
    text-decoration: none;
  }
  .back-link i {
    transition: transform 0.2s;
  }
  .back-link:hover i {
    transform: translateX(-3px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .admin-header {
      margin-bottom: 1.25rem;
    }
    .admin-header h2 {
      font-size: 1.4rem;
    }
    .stats-row {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
    .stat-card {
      padding: 1rem;
    }
    .stat-card h3 {
      font-size: 1.6rem;
    }
    .clinic-card {
      flex-direction: column;
      align-items: flex-start;
      padding: 1.25rem;
      gap: 0.75rem;
    }
    .clinic-info {
      min-width: 100%;
    }
    .clinic-meta span {
      display: inline-block;
      margin-bottom: 0.35rem;
    }
    .clinic-actions {
      width: 100%;
      justify-content: flex-start;
    }
    .clinic-actions .btn,
    .clinic-actions form {
      flex: 1 1 auto;
      min-width: 120px;
    }
    .clinic-actions .btn {
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    .stats-row {
      grid-template-columns: 1fr 1fr;
    }
    .clinic-actions {
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
    }
    .clinic-actions .btn,
    .clinic-actions form {
      width: 100%;
      min-width: unset;
    }
  }
</style>

<a href="/admin" class="back-link">
  <i class="fa-solid fa-arrow-left"></i>Back to Admin Panel
</a>

<div class="admin-header">
  <i class="fa-solid fa-hospital"></i>
  <h2>Manage Clinics</h2>
</div>

<%
  const totalClinics = clinics.length;
  const activeDoctors = clinics.filter(c => c.ownerId && c.ownerId.isActive).length;
  const inactiveDoctors = clinics.filter(c => c.ownerId && !c.ownerId.isActive).length;
%>

<div class="stats-row">
  <div class="stat-card">
    <h3><%= totalClinics %></h3>
    <p>Total Clinics</p>
  </div>
  <div class="stat-card">
    <h3><%= activeDoctors %></h3>
    <p>Active Doctors</p>
  </div>
  <div class="stat-card">
    <h3><%= inactiveDoctors %></h3>
    <p>Inactive Doctors</p>
  </div>
</div>

<% if (clinics.length === 0) { %>
  <div class="alert alert-info">
    <i class="fa-solid fa-info-circle me-2"></i>No clinics found.
  </div>
<% } else { %>
  <% clinics.forEach(function(clinic) { %>
    <div class="clinic-card">
      <div class="clinic-info">
        <h5>
          <i class="fa-solid fa-hospital text-primary"></i><%= clinic.name %>
        </h5>
        <div class="clinic-meta">
          <% if (clinic.location) { %>
            <span><i class="fa-solid fa-location-dot me-1"></i><%= clinic.location %></span>
          <% } %>
          <span><i class="fa-regular fa-calendar me-1"></i><%= new Date(clinic.createdAt).toLocaleDateString() %></span>
        </div>
        <% if (clinic.ownerId) { %>
          <div class="mt-2">
            <span class="badge bg-info text-dark me-2">
              <i class="fa-solid fa-user-doctor me-1"></i>Dr. <%= clinic.ownerId.name %>
            </span>
            <span class="badge bg-secondary">
              <i class="fa-solid fa-phone me-1"></i><%= clinic.ownerId.phone %>
            </span>
            <% if (clinic.ownerId.isActive) { %>
              <span class="badge-status badge-active ms-2">Active</span>
            <% } else { %>
              <span class="badge-status badge-inactive ms-2">Inactive</span>
            <% } %>
          </div>
        <% } else { %>
          <div class="mt-2">
            <span class="badge bg-warning text-dark">No Doctor Assigned</span>
          </div>
        <% } %>
      </div>
      <div class="clinic-actions">
        <% if (clinic.ownerId) { %>
          <a href="/admin/users/<%= clinic.ownerId._id %>" class="btn btn-outline-primary btn-sm">
            <i class="fa-solid fa-eye me-1"></i>View Doctor
          </a>
        <% } %>
        <form action="/admin/clinics/<%= clinic._id %>/delete" method="POST" 
              onsubmit="return confirm('Are you sure you want to delete clinic: <%= clinic.name %>? This action cannot be undone.');">
          <button type="submit" class="btn btn-danger btn-sm">
            <i class="fa-solid fa-trash me-1"></i>Delete Clinic
          </button>
        </form>
      </div>
    </div>
  <% }) %>
<% } %>

