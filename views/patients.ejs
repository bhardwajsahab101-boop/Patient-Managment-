<% title = 'Patients' %>
<% extraStyles = ['/css/patients.css'] %>

<%- layout("./layout/boilerPlate.ejs") %>

<!-- Header -->
<div class="page-header d-flex justify-content-between align-items-center mb-4">
  <div>
    <h3 class="fw-bold mb-1">Patients</h3>
    <p class="text-muted mb-0">Manage your patient records</p>
  </div>
  <a href="/patients/new" class="btn btn-primary ">
    <i class="fas fa-plus me-2"></i>Add Patient
  </a>
</div>

<!-- Search & Filter Toolbar -->
<div class="toolbar-card mb-4">
  <form action="/patients" method="GET" class="row g-3 align-items-center">
    <div class="col-md-6">
      <div class="search-box">
        <i class="fas fa-search search-icon"></i>
        <input type="text" name="q" class="form-control search-input" placeholder="Search by name or phone..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" autocomplete="off">
      </div>
    </div>
    <div class="col-md-6 d-flex justify-content-md-end gap-2">
      <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
        <a href="/patients" class="btn btn-outline-secondary">
          <i class="fas fa-xmark me-1"></i>Clear
        </a>
      <% } %>
      <select class="form-select w-auto" disabled title="Coming soon">
        <option>All Patients</option>
        <option>Overdue</option>
        <option>Today</option>
        <option>Upcoming</option>
      </select>
      <select class="form-select w-auto" disabled title="Coming soon">
        <option>Latest First</option>
        <option>Oldest First</option>
        <option>A-Z</option>
      </select>
    </div>
  </form>
</div>

<!-- Patients Grid -->
<div class="row">
  <% if (patients.length === 0) { %>
    <div class="col-12">
      <div class="empty-box">
        <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
          <i class="fas fa-search fa-3x mb-3"></i>
          <h4>No patients found</h4>
          <p>No results matching "<strong><%= searchQuery %></strong>". Try a different search term.</p>
          <a href="/patients" class="btn btn-outline-primary mt-2">
            <i class="fas fa-arrow-left me-1"></i>View All Patients
          </a>
        <% } else { %>
          <i class="fas fa-user-plus fa-3x mb-3"></i>
          <h4>No patients yet</h4>
          <p>Get started by adding your first patient to the system.</p>
          <a href="/patients/new" class="btn btn-primary mt-2 text-white">
            <i class="fas fa-plus me-1"></i>Add Patient
          </a>
        <% } %>
      </div>
    </div>
  <% } else { %>
    <% for (let patient of patients) { %>
      <%
        const latestVisit = (patient.visits && patient.visits.length)
          ? patient.visits[patient.visits.length - 1]
          : null;
        let status = "", statusClass = "", statusBadge = "bg-secondary";
        if (latestVisit && latestVisit.nextVisit) {
          const today = new Date(); const next = new Date(latestVisit.nextVisit);
          today.setHours(0,0,0,0); next.setHours(0,0,0,0);
          if (next.getTime() === today.getTime()) {
            status = "Today"; statusClass = "status-today"; statusBadge = "bg-warning text-dark";
          } else if (next < today) {
            status = "Overdue"; statusClass = "status-overdue"; statusBadge = "bg-danger";
          } else {
            status = "Upcoming"; statusClass = "status-upcoming"; statusBadge = "bg-success";
          }
        }
      %>

      <div class="col-lg-4 col-md-6 mb-4">
        <div class="patient-card-wrapper">
          <div class="patient-card h-100">
            <div class="patient-card-header">
              <div class="d-flex justify-content-between align-items-start">
                <div class="d-flex align-items-center gap-3">
                  <div class="patient-avatar"><%= patient.name.charAt(0).toUpperCase() %></div>
                  <div>
                    <h5 class="patient-name mb-1"><%= patient.name %></h5>
                    <span class="badge bg-light text-dark"><%= patient.age || '-' %> yrs &bull; <%= patient.gender || '-' %></span>
                  </div>
                </div>
                <% if (status) { %><span class="badge <%= statusBadge %> status-pill"><%= status %></span><% } %>
              </div>
            </div>
            <div class="patient-card-body">
              <div class="info-row"><i class="fas fa-phone text-primary"></i><span><%= patient.phone %></span></div>
              <div class="info-row"><i class="fas fa-stethoscope text-primary"></i><span><%= patient.treatment || 'General Checkup' %></span></div>
              <div class="info-row"><i class="far fa-calendar text-primary"></i><span>Last Visit: <%= latestVisit && latestVisit.date ? new Date(latestVisit.date).toDateString() : 'N/A' %></span></div>
              <div class="info-row"><i class="far fa-calendar-check text-primary"></i><span>Next Visit: <% if (latestVisit && latestVisit.nextVisit) { %><strong class="<%= statusClass %>"><%= new Date(latestVisit.nextVisit).toDateString() %></strong><% } else { %><span class="text-muted">Not Scheduled</span><% } %></span></div>
            </div>
            <div class="patient-card-footer">
              <a href="/patient/<%= patient._id %>" class="btn btn-sm btn-outline-primary action-btn-sm"><i class="fas fa-eye me-1"></i>View</a>
              <a href="/message/<%= patient._id %>" class="btn btn-sm btn-success action-btn-sm"><i class="fab fa-whatsapp me-1"></i>Message</a>
              <a href="/patients/<%= patient._id %>/edit" class="btn btn-sm btn-outline-warning action-btn-sm"><i class="fas fa-edit me-1"></i>Edit</a>
              <a href="/patients/<%= patient._id %>/delete" class="btn btn-sm btn-outline-danger action-btn-sm"><i class="fas fa-trash me-1"></i>Delete</a>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  <% } %>
</div>

<% if (totalPages > 1) { %>
<div class="pagination-wrapper">
  <nav aria-label="Page navigation">
    <ul class="pagination">
      <li class="page-item <%= currentPage > 1 ? '' : 'disabled' %>">
        <% if (currentPage > 1) { %><a class="page-link" href="/patients?page=<%= currentPage - 1 %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>"><i class="fas fa-chevron-left"></i></a><% } else { %><span class="page-link"><i class="fas fa-chevron-left"></i></span><% } %>
      </li>
      <% for (let i = 1; i <= totalPages; i++) { %>
        <% if (i === currentPage) { %><li class="page-item active"><span class="page-link"><%= i %></span></li>
        <% } else if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) { %><li class="page-item"><a class="page-link" href="/patients?page=<%= i %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>"><%= i %></a></li>
        <% } else if (i === currentPage - 2 || i === currentPage + 2) { %><li class="page-item disabled"><span class="page-link">...</span></li><% } %>
      <% } %>
      <li class="page-item <%= currentPage < totalPages ? '' : 'disabled' %>">
        <% if (currentPage < totalPages) { %><a class="page-link" href="/patients?page=<%= currentPage + 1 %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>"><i class="fas fa-chevron-right"></i></a><% } else { %><span class="page-link"><i class="fas fa-chevron-right"></i></span><% } %>
      </li>
    </ul>
  </nav>
</div>
<% } %>

