<% title = 'Patients' %>
<% extraStyles = ['/css/patients.css'] %>

<%- layout("./layout/boilerPlate.ejs") %>

<!-- Header -->
<div class="page-header d-flex justify-content-between align-items-center mb-4">
  <div>
    <h3 class="fw-bold mb-1">Patients</h3>
    <p class="text-muted mb-0">Manage your patient records</p>
  </div>
  <a href="/patients/new" class="btn btn-header-add">
    <i class="fas fa-plus me-2"></i>Add Patient
  </a>
</div>

<!-- Payment Summary -->
<% 
  let grandTotal = 0, grandPaid = 0, grandPending = 0;
  if (typeof summaryTotals !== 'undefined') {
    grandTotal = summaryTotals.total || 0;
    grandPaid = summaryTotals.paid || 0;
    grandPending = summaryTotals.pending || 0;
  } else {
    patients.forEach(p => {
      let pTotal = 0;
      if (p.visits) { p.visits.forEach(v => { pTotal += (v.price || 0); }); }
      const total = p.totalPayment || pTotal;
      const paid = p.paidPayment || 0;
      grandTotal += total;
      grandPaid += paid;
      grandPending += Math.max(0, total - paid);
    });
  }

  // Dynamic labels based on status filter
  let summaryLabel = "All Time";
  if (typeof status !== 'undefined') {
    if (status === "today") summaryLabel = "Today";
    else if (status === "overdue") summaryLabel = "Overdue";
    else if (status === "upcoming") summaryLabel = "Upcoming";
  }
%>
<% if (patients.length > 0 || (typeof summaryTotals !== 'undefined' && summaryTotals.total >= 0)) { %>
<div class="alert alert-info mb-4">
  <div class="row text-center">
    <div class="col-4">
      <small class="text-dark">Total <%= summaryLabel %></small>
      <div class="h4 mb-0 text-primary">₹<%= grandTotal.toFixed(0) %></div>
    </div>
    <div class="col-4">
      <small class="text-dark">Paid <%= summaryLabel %></small>
      <div class="h4 mb-0 text-success">₹<%= grandPaid.toFixed(0) %></div>
    </div>
    <div class="col-4">
      <small class="text-dark">Pending <%= summaryLabel %></small>
      <div class="h4 mb-0 text-danger">₹<%= grandPending.toFixed(0) %></div>
    </div>
  </div>
</div>
<% } %>

<!-- Search & Filter Toolbar -->
<div class="toolbar-card mb-4">
  <form action="/patients" method="GET" class="row g-3 align-items-center">
    <div class="col-md-6">
<div class="search-box">
        <i class="fas fa-search search-icon"></i>
        <input type="text" name="q" class="form-control search-input" placeholder="Search by name or phone..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" autocomplete="off" oninput="let p=this.form; clearTimeout(p.timeout); p.timeout=setTimeout(()=>p.submit(),300)">
      </div>
    </div>
    <div class="col-md-6 d-flex justify-content-md-end gap-2">
      <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
        <a href="/patients" class="btn btn-outline-secondary">
          <i class="fas fa-xmark me-1"></i>Clear
        </a>
      <% } %>
<select class="form-select w-auto" name="status" onchange="this.form.submit()">
        <option value="all" <%= typeof status !== 'undefined' && status === 'all' ? 'selected' : '' %>>All Patients</option>
        <option value="overdue" <%= typeof status !== 'undefined' && status === 'overdue' ? 'selected' : '' %>>Overdue</option>
        <option value="today" <%= typeof status !== 'undefined' && status === 'today' ? 'selected' : '' %>>Added Today</option>
        <option value="upcoming" <%= typeof status !== 'undefined' && status === 'upcoming' ? 'selected' : '' %>>Upcoming</option>
      </select>
      <select class="form-select w-auto" name="sort" onchange="this.form.submit()">
        <option value="latest" <%= typeof sort !== 'undefined' && sort === 'latest' ? 'selected' : '' %>>Latest First</option>
        <option value="oldest" <%= typeof sort !== 'undefined' && sort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
        <option value="az" <%= typeof sort !== 'undefined' && sort === 'az' ? 'selected' : '' %>>A-Z</option>
      </select>
    </div>
  </form>
</div>

<!-- Patients Grid -->
<div class="row">
  <% if (patients.length === 0) { %>
    <div class="col-12">
      <div class="empty-box">
        <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
          <i class="fas fa-search fa-3x mb-3"></i>
          <h4>No patients found</h4>
          <p>No results matching "<strong><%= searchQuery %></strong>". Try a different search term.</p>
          <a href="/patients" class="btn btn-outline-primary mt-2">
            <i class="fas fa-arrow-left me-1"></i>View All Patients
          </a>
        <% } else { %>
          <i class="fas fa-user-plus fa-3x mb-3"></i>
          <h4>No patients yet</h4>
          <p>Get started by adding your first patient to the system.</p>
          <a href="/patients/new" class="btn btn-primary mt-2 text-white">
            <i class="fas fa-plus me-1"></i>Add Patient
          </a>
        <% } %>
      </div>
    </div>
  <% } else { %>
    <% for (let patient of patients) { %>
      <%
        const latestVisit = (patient.visits && patient.visits.length)
          ? patient.visits[patient.visits.length - 1]
          : null;
        let status = "", statusClass = "", statusBadge = "bg-secondary";
        if (latestVisit && latestVisit.nextVisit) {
          const today = new Date(); const next = new Date(latestVisit.nextVisit);
          today.setHours(0,0,0,0); next.setHours(0,0,0,0);
          if (next.getTime() === today.getTime()) {
            status = "Today"; statusClass = "status-today"; statusBadge = "bg-warning text-dark";
          } else if (next < today) {
            status = "Overdue"; statusClass = "status-overdue"; statusBadge = "bg-danger";
          } else {
            status = "Upcoming"; statusClass = "status-upcoming"; statusBadge = "bg-success";
          }
        }
      %>

      <div class="col-lg-4 col-md-6 mb-4">
        <div class="patient-card-wrapper">
          <div class="patient-card h-100">
            <div class="patient-card-header">
              <div class="d-flex justify-content-between align-items-start">
                <div class="d-flex align-items-center gap-3">
                  <div class="patient-avatar"><%= patient.name.charAt(0).toUpperCase() %></div>
                  <div>
                    <h5 class="patient-name mb-1"><%= patient.name %></h5>
                    <span class="badge bg-light text-dark"><%= patient.age || '-' %> yrs &bull; <%= patient.gender || '-' %></span>
                  </div>
                </div>
                <% if (status) { %><span class="badge <%= statusBadge %> status-pill"><%= status %></span><% } %>
              </div>
            </div>
<div class="patient-card-body">
              <div class="info-row"><i class="fas fa-phone text-primary"></i><span><%= patient.phone %></span></div>
              <div class="info-row"><i class="fas fa-stethoscope text-primary"></i><span><%= patient.treatment || 'General Checkup' %></span></div>
              <div class="info-row"><i class="far fa-calendar text-primary"></i><span>Last Visit: <%= latestVisit && latestVisit.date ? new Date(latestVisit.date).toDateString() : 'N/A' %></span></div>
              <div class="info-row"><i class="far fa-calendar-check text-primary"></i><span>Next Visit: <% if (latestVisit && latestVisit.nextVisit) { %><strong class="<%= statusClass %>"><%= new Date(latestVisit.nextVisit).toDateString() %></strong><% } else { %><span class="text-muted">Not Scheduled</span><% } %></span></div>
              <!-- Payment Info -->
              <% 
                let totalFromVisits = 0;
                if (patient.visits) {
                  patient.visits.forEach(v => { totalFromVisits += (v.price || 0); });
                }
                const totalAll = patient.totalPayment || totalFromVisits;
                const paidAll = patient.paidPayment || 0;
                const pendingAll = Math.max(0, totalAll - paidAll);
              %>
              <div class="info-row mt-2 pt-2 border-top">
                <div class="row text-center">
                  <div class="col-4">
                    <small class="text-muted">Total</small>
                    <div class="fw-bold text-primary">₹<%= totalAll.toFixed(0) %></div>
                  </div>
                  <div class="col-4">
                    <small class="text-muted">Paid</small>
                    <div class="fw-bold text-success">₹<%= paidAll.toFixed(0) %></div>
                  </div>
                  <div class="col-4">
                    <small class="text-muted">Pending</small>
                    <div class="fw-bold text-danger">₹<%= pendingAll.toFixed(0) %></div>
                  </div>
                </div>
              </div>
            </div>
<div class="patient-card-footer btn-action-group">
              <a href="/patient/<%= patient._id %>" class="btn-action-card btn-view-card font-weight-bold">
                <i class="fas fa-eye">  </i> View
              </a>
              <a href="/message/<%= patient._id %>" class="btn-action-card btn-whatsapp-card">
                <i class="fab fa-whatsapp"></i>
              </a>
              
              <a href="/patients/<%= patient._id %>/visits/new" class="btn-action-card btn-add-card">
                <i class="fas fa-plus"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  <% } %>
</div>

<% 
  const buildQuery = (pageNum) => {
    const params = new URLSearchParams();
    if (pageNum > 1) params.set('page', pageNum);
    if (typeof searchQuery !== 'undefined' && searchQuery) params.set('q', searchQuery);
    if (typeof status !== 'undefined' && status !== 'all') params.set('status', status);
    if (typeof sort !== 'undefined' && sort !== 'latest') params.set('sort', sort);
    return params.toString() ? '?' + params.toString() : '/patients';
  };
%>
<% if (totalPages > 1) { %>
<div class="pagination-wrapper">
  <nav aria-label="Page navigation">
    <ul class="pagination">
      <li class="page-item <%= currentPage > 1 ? '' : 'disabled' %>">
        <% if (currentPage > 1) { %><a class="page-link" href="<%= buildQuery(currentPage - 1) %>"><i class="fas fa-chevron-left"></i></a><% } else { %><span class="page-link"><i class="fas fa-chevron-left"></i></span><% } %>
      </li>
      <% for (let i = 1; i <= totalPages; i++) { %>
        <% if (i === currentPage) { %><li class="page-item active"><span class="page-link"><%= i %></span></li>
        <% } else if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) { %><li class="page-item"><a class="page-link" href="<%= buildQuery(i) %>"><%= i %></a></li>
        <% } else if (i === currentPage - 2 || i === currentPage + 2) { %><li class="page-item disabled"><span class="page-link">...</span></li><% } %>
      <% } %>
      <li class="page-item <%= currentPage < totalPages ? '' : 'disabled' %>">
        <% if (currentPage < totalPages) { %><a class="page-link" href="<%= buildQuery(currentPage + 1) %>"><i class="fas fa-chevron-right"></i></a><% } else { %><span class="page-link"><i class="fas fa-chevron-right"></i></span><% } %>
      </li>
    </ul>
  </nav>
</div>
<% } %>

