<%- layout("./layout/auth.ejs") %>

<div class="auth-logo">
  <i class="fa-solid fa-hospital-user text-primary"></i>
  <h4>Create Your Clinic</h4>
  <p class="text-muted mb-0">Let's set up your practice</p>
</div>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<form action="/create-clinic" method="POST">
  <div class="mb-3">
    <label class="form-label fw-semibold">Clinic Name</label>
    <input
      type="text"
      name="name"
      class="form-control"
      placeholder="e.g. City Health Care"
      required
    />
  </div>

  <div class="mb-4">
    <label class="form-label fw-semibold">Location</label>
    <input
      type="text"
      name="location"
      class="form-control"
      placeholder="City, Area, Address"
    />
  </div>

  <button type="submit" class="btn btn-auth">Create Clinic</button>
</form>

<form action="/logout" method="POST" class="mt-3 text-center">
  <button type="submit" class="btn btn-outline-secondary btn-sm">
    <i class="fa-solid fa-arrow-right-from-bracket me-1"></i> Logout
  </button>
</form>

