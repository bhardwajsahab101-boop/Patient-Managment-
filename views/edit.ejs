<% title = 'Edit Patient' %>
<% extraStyles = ['/css/forms.css'] %>

<%- layout("./layout/boilerPlate.ejs") %>

<h3 class="fw-bold mb-4">Edit Patient</h3>

<div class="card p-4 shadow-sm">
  <% if (typeof errors !== 'undefined' && errors && errors.length) { %>
    <div class="alert alert-danger mb-4">
      <% errors.forEach(function(e) { %>
        <div><%= e.msg %></div>
      <% }) %>
    </div>
  <% } %>
  <form action="/patients/<%= patient._id %>?_method=PUT" method="POST">
    
    <!-- PATIENT INFO -->
    <div class="mb-3">
      <label class="form-label">Name</label>
      <input type="text" name="patient[name]" value="<%= patient.name %>" class="form-control" required />
    </div>

    <div class="mb-3">
      <label class="form-label">Age</label>
      <input type="number" name="patient[age]" value="<%= patient.age %>" class="form-control" />
    </div>

    <div class="mb-3">
      <label class="form-label">Gender</label>
      <select name="patient[gender]" class="form-select">
        <option <%= patient.gender === 'Male' ? 'selected' : '' %>>Male</option>
        <option <%= patient.gender === 'Female' ? 'selected' : '' %>>Female</option>
        <option <%= patient.gender === 'Other' ? 'selected' : '' %>>Other</option>
      </select>
    </div>

    <div class="mb-3">
      <label class="form-label">Phone</label>
      <input type="text" name="patient[phone]" value="<%= patient.phone %>" class="form-control" required />
    </div>

    <div class="mb-3">
      <label class="form-label">Treatment</label>
      <input type="text" name="patient[treatment]" value="<%= patient.treatment %>" class="form-control" />
    </div>

    <div class="mb-3">
      <label class="form-label">Address</label>
      <textarea name="patient[address]" class="form-control" rows="2"
        placeholder="Enter patient's full address"><%= patient.address || '' %></textarea>
    </div>

<div class="mb-3">
      <label class="form-label">Next Visit Date</label>
      <input type="date" name="visit[nextVisit]" value="<%= patient.nextVisit ? new Date(patient.nextVisit).toISOString().split('T')[0] : '' %>" class="form-control" />
    </div>

<!-- Payment Fields -->
    <div class="row">
      <div class="col-md-4 mb-3">
        <label class="form-label">Total Payment (₹)</label>
        <input type="number" name="patient[totalPayment]" id="totalPayment" value="<%= patient.totalPayment || 0 %>" class="form-control" min="0" step="0.01" oninput="updatePending()" />
      </div>
      <div class="col-md-4 mb-3">
        <label class="form-label">Paid Amount (₹)</label>
        <input type="number" name="patient[paidPayment]" id="paidPayment" value="<%= patient.paidPayment || '' %>" class="form-control" min="0" step="0.01" placeholder="Leave empty for full payment" oninput="updatePending()" />
      </div>
      <div class="col-md-4 mb-3">
        <label class="form-label">Pending Amount (₹)</label>
        <input type="text" id="pendingPayment" class="form-control" value="<%= typeof patient.pendingPayment !== 'undefined' ? patient.pendingPayment.toFixed(2) : '0.00' %>" readonly />
      </div>
    </div>

    <div class="mt-4 d-flex gap-2">
      <button type="submit" class="btn btn-primary">Update Patient</button>
      <a href="/patients" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>

<script>
  function updatePending() {
    const total = parseFloat(document.getElementById('totalPayment').value) || 0;
    let paid = document.getElementById('paidPayment').value;
    // If paid is empty, default to total (fully paid)
    if (paid === '' || paid === null || isNaN(parseFloat(paid))) {
      paid = total;
      document.getElementById('paidPayment').value = '';
    } else {
      paid = parseFloat(paid);
    }
    const pending = Math.max(0, total - paid);
    document.getElementById('pendingPayment').value = pending.toFixed(2);
  }
  // Initialize on page load
  updatePending();
</script>
