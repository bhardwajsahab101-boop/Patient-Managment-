<% title = 'Edit Patient' %>
<% extraStyles = ['/css/forms.css'] %>

<%- layout("./layout/boilerPlate.ejs") %>

<h3 class="fw-bold mb-4">Edit Patient</h3>

<div class="card p-4 shadow-sm">
  <form action="/patients/<%= patient._id %>?_method=PUT" method="POST">
    
    <!-- PATIENT INFO -->
    <div class="mb-3">
      <label class="form-label">Name</label>
      <input type="text" name="patient[name]" value="<%= patient.name %>" class="form-control" required />
    </div>

    <div class="mb-3">
      <label class="form-label">Age</label>
      <input type="number" name="patient[age]" value="<%= patient.age %>" class="form-control" />
    </div>

    <div class="mb-3">
      <label class="form-label">Gender</label>
      <select name="patient[gender]" class="form-select">
        <option <%= patient.gender === 'Male' ? 'selected' : '' %>>Male</option>
        <option <%= patient.gender === 'Female' ? 'selected' : '' %>>Female</option>
        <option <%= patient.gender === 'Other' ? 'selected' : '' %>>Other</option>
      </select>
    </div>

    <div class="mb-3">
      <label class="form-label">Phone</label>
      <input type="text" name="patient[phone]" value="<%= patient.phone %>" class="form-control" required />
    </div>

    <div class="mb-3">
      <label class="form-label">Treatment</label>
      <input type="text" name="patient[treatment]" value="<%= patient.treatment %>" class="form-control" />
    </div>

    <div class="mb-3">
      <label class="form-label">Next Visit Date</label>
      <input type="date" name="visit[nextVisit]" value="<%= patient.nextVisit ? new Date(patient.nextVisit).toISOString().split('T')[0] : '' %>" class="form-control" />
    </div>

    <div class="mt-4 d-flex gap-2">
      <button type="submit" class="btn btn-primary">Update Patient</button>
      <a href="/patients" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>
