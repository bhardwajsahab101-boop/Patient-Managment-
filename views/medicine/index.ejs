<%- layout("./layout/boilerPlate.ejs") %>

<body>
  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h3 class="fw-bold">💊 Medicines</h3>
      <a href="/medicines/new?clinicId=<%= (medicines && medicines[0] && medicines[0].clinicId) ? medicines[0].clinicId : (clinicId || '') %>" class="btn btn-primary">
        + Add Medicine
      </a>
    </div>

    <!-- Search & Filters -->
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <form method="GET" action="/medicines" class="row g-2 align-items-end">
          <input type="hidden" name="clinicId" value="<%= (medicines && medicines[0] && medicines[0].clinicId) ? medicines[0].clinicId : (clinicId || '') %>">
          
          <div class="col-md-3">
            <label class="form-label small text-muted">Search</label>
            <input type="text" name="q" class="form-control" placeholder="Name, manufacturer, batch..." value="<%= q %>">
          </div>
          
          <div class="col-md-2">
            <label class="form-label small text-muted">Category</label>
            <select name="category" class="form-select">
              <option value="">All</option>
              <% categories.forEach(cat => { %>
                <option value="<%= cat %>" <%= category === cat ? 'selected' : '' %>><%= cat %></option>
              <% }) %>
            </select>
          </div>
          
          <div class="col-md-2">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="lowStock" value="true" id="lowStockCheck" <%= lowStock ? 'checked' : '' %>>
              <label class="form-check-label small" for="lowStockCheck">Low Stock (≤5)</label>
            </div>
          </div>
          
          <div class="col-md-2">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="expiring" value="true" id="expiringCheck" <%= expiring ? 'checked' : '' %>>
              <label class="form-check-label small" for="expiringCheck">Expiring Soon</label>
            </div>
          </div>
          
          <div class="col-md-3">
            <button class="btn btn-outline-primary w-100">Apply Filters</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Medicines Table -->
    <div class="card shadow-sm">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Name</th>
              <th>Category</th>
              <th>Dosage</th>
              <th>Stock</th>
              <th>Buy Price</th>
              <th>Sell Price</th>
              <th>Expiry</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>
            <% medicines.forEach(med => { %>
              <% 
                const today = new Date();
                today.setHours(0,0,0,0);
                let expiryWarning = false;
                let expired = false;
                if (med.expiryDate) {
                  const exp = new Date(med.expiryDate);
                  exp.setHours(0,0,0,0);
                  const diffDays = Math.ceil((exp - today) / (1000 * 60 * 60 * 24));
                  if (diffDays < 0) expired = true;
                  else if (diffDays <= 30) expiryWarning = true;
                }
              %>
              <tr>
                <td class="fw-semibold">
                  <a href="/medicines/<%= med._id %>" class="text-decoration-none"><%= med.name %></a>
                  <% if (med.manufacturer) { %>
                    <br><small class="text-muted"><%= med.manufacturer %></small>
                  <% } %>
                </td>
                <td><span class="badge bg-info text-dark"><%= med.category || 'Tablet' %></span></td>
                <td><%= med.dosage || '-' %></td>

                <td>
                  <% if (med.stock <= 5) { %>
                    <span class="badge bg-danger"><%= med.stock %></span>
                  <% } else if (med.stock <= 20) { %>
                    <span class="badge bg-warning text-dark"><%= med.stock %></span>
                  <% } else { %>
                    <span class="badge bg-success"><%= med.stock %></span>
                  <% } %>
                </td>

                <td>₹<%= med.buyPrice || 0 %></td>
                <td>₹<%= med.sellPrice || 0 %></td>

                <td>
                  <% if (expired) { %>
                    <span class="badge bg-danger">Expired</span>
                  <% } else if (expiryWarning) { %>
                    <span class="badge bg-warning text-dark">Soon</span>
                  <% } else if (med.expiryDate) { %>
                    <span class="badge bg-success">OK</span>
                  <% } else { %>
                    <span class="text-muted">-</span>
                  <% } %>
                </td>

                <td>
                  <div class="d-flex gap-1 flex-wrap">
                    <a href="/medicines/add/<%= med._id %>" class="btn btn-sm btn-success" title="+1 Stock">+</a>
                    <a href="/medicines/remove/<%= med._id %>" class="btn btn-sm btn-outline-danger" title="-1 Stock">−</a>
                    <a href="/medicines/<%= med._id %>/update" class="btn btn-sm btn-primary">Stock</a>
                    <a href="/medicines/<%= med._id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <form action="/medicines/<%= med._id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this medicine?');">
                      <button class="btn btn-sm btn-outline-danger">Del</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <% if (medicines.length === 0) { %>
      <div class="text-center mt-5">
        <h5>No medicines found</h5>
        <a href="/medicines/new?clinicId=<%= clinicId %>" class="btn btn-primary mt-2">Add First Medicine</a>
      </div>
    <% } %>
  </div>

  <style>
    table td, table th {
      vertical-align: middle;
    }
    .badge {
      font-size: 0.85rem;
    }
  </style>
</body>

