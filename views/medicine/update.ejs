<%- layout("./layout/boilerPlate.ejs") %>
<div class="container mt-4">
  <h3 class="fw-bold mb-4">Update Stock - <%= medicine.name %></h3>

  <div class="alert alert-info">
    <strong>Current Stock:</strong> <%= medicine.stock %>
  </div>

  <form action="/medicines/<%= medicine._id %>/update" method="POST" class="card p-4 shadow-sm">

    <div class="row">
      <div class="col-md-4 mb-3">
        <label class="form-label">Type</label>
        <select name="type" class="form-select">
          <option value="IN">Add Stock (IN)</option>
          <option value="OUT">Remove Stock (OUT)</option>
        </select>
      </div>

      <div class="col-md-4 mb-3">
        <label class="form-label">Quantity</label>
        <input type="number" name="quantity" class="form-control" min="1" required>
      </div>

      <div class="col-md-4 mb-3">
        <label class="form-label">Patient (optional)</label>
        <select name="patientId" class="form-select">
          <option value="">-- Select Patient --</option>
          <% patients.forEach(p => { %>
            <option value="<%= p._id %>"><%= p.name %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="mb-3">
      <label class="form-label">Note</label>
      <input type="text" name="note" class="form-control" placeholder="e.g. Purchased from supplier / Used for patient">
    </div>

    <div class="d-flex gap-2">
      <button class="btn btn-primary">Update Stock</button>
      <a href="/medicines" class="btn btn-outline-secondary">Cancel</a>
    </div>
  </form>
</div>

