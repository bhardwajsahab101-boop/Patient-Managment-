<%- layout("./layout/boilerPlate.ejs") %>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold">💊 <%= medicine.name %></h3>
    <div class="d-flex gap-2">
      <a href="/medicines/<%= medicine._id %>/edit" class="btn btn-outline-secondary">Edit</a>
      <a href="/medicines/<%= medicine._id %>/update" class="btn btn-primary">Update Stock</a>
      <a href="/medicines" class="btn btn-outline-dark">Back</a>
    </div>
  </div>

  <div class="row">
    <!-- Medicine Info Card -->
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm h-100">
        <div class="card-header bg-primary text-white">
          <h5 class="mb-0">Medicine Details</h5>
        </div>
        <div class="card-body">
          <table class="table table-borderless mb-0">
            <tr>
              <td class="fw-bold text-muted" style="width: 35%">Name</td>
              <td><%= medicine.name %></td>
            </tr>
            <tr>
              <td class="fw-bold text-muted">Category</td>
              <td><span class="badge bg-info text-dark"><%= medicine.category || 'Tablet' %></span></td>
            </tr>
            <tr>
              <td class="fw-bold text-muted">Dosage</td>
              <td><%= medicine.dosage || '-' %></td>
            </tr>
            <tr>
              <td class="fw-bold text-muted">Manufacturer</td>
              <td><%= medicine.manufacturer || '-' %></td>
            </tr>
            <tr>
              <td class="fw-bold text-muted">Batch Number</td>
              <td><%= medicine.batchNumber || '-' %></td>
            </tr>
            <tr>
              <td class="fw-bold text-muted">Expiry Date</td>
              <td>
                <% if (medicine.expiryDate) { %>
                  <% 
                    const today = new Date(); today.setHours(0,0,0,0);
                    const exp = new Date(medicine.expiryDate); exp.setHours(0,0,0,0);
                    const diffDays = Math.ceil((exp - today) / (1000 * 60 * 60 * 24));
                  %>
                  <%= new Date(medicine.expiryDate).toDateString() %>
                  <% if (diffDays < 0) { %>
                    <span class="badge bg-danger ms-2">Expired</span>
                  <% } else if (diffDays <= 30) { %>
                    <span class="badge bg-warning text-dark ms-2">Expiring in <%= diffDays %> days</span>
                  <% } %>
                <% } else { %>
                  <span class="text-muted">-</span>
                <% } %>
              </td>
            </tr>
            <tr>
              <td class="fw-bold text-muted">Description</td>
              <td><%= medicine.description || '-' %></td>
            </tr>
            <tr>
              <td class="fw-bold text-muted">Buy Price</td>
              <td>₹<%= medicine.buyPrice || 0 %></td>
            </tr>
            <tr>
              <td class="fw-bold text-muted">Sell Price</td>
              <td>₹<%= medicine.sellPrice || 0 %></td>
            </tr>
            <tr>
              <td class="fw-bold text-muted">Current Stock</td>
              <td>
                <% if (medicine.stock <= 5) { %>
                  <span class="badge bg-danger fs-6"><%= medicine.stock %></span>
                <% } else if (medicine.stock <= 20) { %>
                  <span class="badge bg-warning text-dark fs-6"><%= medicine.stock %></span>
                <% } else { %>
                  <span class="badge bg-success fs-6"><%= medicine.stock %></span>
                <% } %>
              </td>
            </tr>
          </table>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm h-100">
        <div class="card-header bg-success text-white">
          <h5 class="mb-0">Quick Actions</h5>
        </div>
        <div class="card-body d-flex flex-column gap-2">
          <a href="/medicines/add/<%= medicine._id %>" class="btn btn-success">+1 Stock</a>
          <a href="/medicines/remove/<%= medicine._id %>" class="btn btn-outline-danger">−1 Stock</a>
          <a href="/medicines/<%= medicine._id %>/update" class="btn btn-primary">Custom Stock Update</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Stock Transaction History -->
  <div class="card shadow-sm">
    <div class="card-header bg-dark text-white">
      <h5 class="mb-0">📋 Stock Transaction History</h5>
    </div>
    <div class="card-body p-0">
      <% if (transactions.length === 0) { %>
        <div class="p-4 text-center text-muted">No transactions yet</div>
      <% } else { %>
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Date</th>
              <th>Type</th>
              <th>Qty</th>
              <th>Previous</th>
              <th>New</th>
              <th>Patient</th>
              <th>Note</th>
            </tr>
          </thead>
          <tbody>
            <% transactions.forEach(tx => { %>
              <tr>
                <td><%= new Date(tx.createdAt).toLocaleString() %></td>
                <td>
                  <% if (tx.type === 'IN') { %>
                    <span class="badge bg-success">IN</span>
                  <% } else { %>
                    <span class="badge bg-danger">OUT</span>
                  <% } %>
                </td>
                <td><%= tx.quantity %></td>
                <td><%= tx.previousStock %></td>
                <td><%= tx.newStock %></td>
                <td><%= tx.patientName || '-' %></td>
                <td><%= tx.note || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</div>

