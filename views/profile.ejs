<%- layout("./layout/boilerPlate.ejs") %>

<style>
  /* ===== PROFILE PAGE STYLES ===== */

  .profile-hero-banner {
    background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 50%, #0dcaf0 100%);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(13,110,253,0.3);
  }
  .profile-hero-banner::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
    border-radius: 50%;
  }
  .profile-hero-banner::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: 10%;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
    border-radius: 50%;
  }
  .hero-content {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    position: relative;
    z-index: 1;
  }
  .hero-avatar {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    border: 4px solid rgba(255,255,255,0.3);
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    object-fit: cover;
  }
  .hero-text h2 {
    margin: 0;
    color: #fff;
    font-weight: 800;
    font-size: 1.6rem;
  }
  .hero-text p {
    margin: 0.3rem 0 0 0;
    color: rgba(255,255,255,0.85);
    font-size: 0.95rem;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.6rem;
    padding: 0.35rem 0.9rem;
    background: rgba(255,255,255,0.2);
    border-radius: 20px;
    color: #fff;
    font-size: 0.8rem;
    font-weight: 600;
    border: 1px solid rgba(255,255,255,0.15);
  }

  .profile-card {
    background: #fff;
    border-radius: 20px;
    padding: 1.75rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    border: 1px solid #f1f3f5;
    margin-bottom: 1.5rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .profile-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
  }
  .profile-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: #0d6efd;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .section-icon {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    color: #fff;
  }
  .section-icon.primary { background: linear-gradient(135deg, #0d6efd, #0b5ed7); }
  .section-icon.teal { background: linear-gradient(135deg, #20c997, #0dcaf0); }
  .section-icon.orange { background: linear-gradient(135deg, #fd7e14, #ffc107); }
  .section-icon.purple { background: linear-gradient(135deg, #6f42c1, #a18cd1); }
  .section-title-text {
    font-weight: 700;
    font-size: 1.1rem;
    color: #1a1a2e;
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .info-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: #f8f9fa;
    border-radius: 12px;
    transition: all 0.2s ease;
  }
  .info-item:hover {
    background: #e9ecef;
  }
  .info-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .info-left i {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-size: 0.85rem;
  }
  .info-left i.primary-icon { background: rgba(13,110,253,0.1); color: #0d6efd; }
  .info-left i.teal-icon { background: rgba(32,201,151,0.1); color: #20c997; }
  .info-left i.orange-icon { background: rgba(253,126,20,0.1); color: #fd7e14; }
  .info-label-text {
    font-weight: 500;
    color: #6c757d;
    font-size: 0.9rem;
  }
  .info-value-text {
    font-weight: 700;
    color: #1a1a2e;
    font-size: 0.95rem;
  }

  .plan-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 25px;
    font-size: 0.85rem;
    font-weight: 700;
  }
  .plan-status.active {
    background: #d1fae5;
    color: #065f46;
  }
  .plan-status.expired {
    background: #fee2e2;
    color: #991b1b;
  }
  .plan-status i {
    font-size: 0.5rem;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.2); }
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .stat-card {
    background: #fff;
    border-radius: 20px;
    padding: 1.5rem 1rem;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    border: 1px solid #f1f3f5;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
  }
  .stat-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: #0d6efd;
    border-radius: 0 0 20px 20px;
  }
  .stat-icon {
    width: 50px;
    height: 50px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 0.75rem;
    font-size: 1.25rem;
    color: #fff;
  }
  .stat-icon.patients { background: linear-gradient(135deg, #0d6efd, #0b5ed7); }
  .stat-icon.medicines { background: linear-gradient(135deg, #fd7e14, #ffc107); }
  .stat-icon.visits { background: linear-gradient(135deg, #20c997, #0dcaf0); }
  .stat-number {
    margin: 0;
    font-weight: 800;
    font-size: 2rem;
    color: #1a1a2e;
  }
  .stat-label {
    margin: 0.3rem 0 0 0;
    font-size: 0.8rem;
    color: #6c757d;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .actions-flex {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }
  .action-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: 14px;
    border: 1px solid #e9ecef;
    background: #fff;
    color: #495057;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    width: 100%;
  }
  .action-item:hover {
    border-color: #0d6efd;
    color: #0d6efd;
    transform: translateX(5px);
    box-shadow: 0 4px 15px rgba(13,110,253,0.1);
  }
  .action-item i {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    background: rgba(13,110,253,0.1);
    color: #0d6efd;
  }
  .action-item.danger {
    color: #dc3545;
    border-color: rgba(220,53,69,0.2);
  }
  .action-item.danger i {
    background: rgba(220,53,69,0.1);
    color: #dc3545;
  }
  .action-item.danger:hover {
    border-color: #dc3545;
    color: #dc3545;
  }

  .support-card {
    background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 50%, #6ee7b7 100%);
    border-radius: 20px;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(6,95,70,0.15);
    margin-top: 1rem;
  }
  .support-card::before {
    content: '';
    position: absolute;
    top: -20px;
    right: -20px;
    width: 100px;
    height: 100px;
    background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, transparent 70%);
    border-radius: 50%;
  }
  .support-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: rgba(255,255,255,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: #065f46;
    position: relative;
    z-index: 1;
  }
  .support-text {
    flex: 1;
    position: relative;
    z-index: 1;
  }
  .support-text h5 {
    margin: 0;
    color: #065f46;
    font-weight: 700;
    font-size: 1.1rem;
  }
  .support-text p {
    margin: 0.2rem 0 0 0;
    color: rgba(6,95,70,0.8);
    font-size: 0.85rem;
  }
  .support-btn {
    padding: 0.65rem 1.25rem;
    background: #065f46;
    color: #fff;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    transition: all 0.3s ease;
    position: relative;
    z-index: 1;
    border: none;
    box-shadow: 0 4px 15px rgba(6,95,70,0.3);
    white-space: nowrap;
  }
  .support-btn:hover {
    background: #047857;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(6,95,70,0.4);
    color: #fff;
  }

  .no-clinic-alert {
    background: #fffbeb;
    border: 2px dashed #f59e0b;
    border-radius: 16px;
    padding: 1.5rem;
    text-align: center;
  }
  .no-clinic-alert i {
    font-size: 2rem;
    color: #f59e0b;
    margin-bottom: 0.5rem;
  }
  .no-clinic-alert p {
    margin: 0;
    color: #92400e;
    font-weight: 600;
  }
  .no-clinic-alert a {
    color: #d97706;
    text-decoration: underline;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .profile-hero-banner {
      padding: 1.75rem 1.25rem;
    }
    .hero-content {
      flex-direction: column;
      text-align: center;
    }
    .stats-row {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
    }
    .stat-card {
      padding: 1rem 0.5rem;
    }
    .stat-number {
      font-size: 1.5rem;
    }
    .actions-flex {
      grid-template-columns: 1fr;
    }
    .support-card {
      flex-direction: column;
      text-align: center;
      gap: 0.75rem;
    }
    .info-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.3rem;
    }
  }
  @media (max-width: 480px) {
    .stats-row {
      grid-template-columns: 1fr;
    }
    .hero-avatar {
      width: 70px;
      height: 70px;
    }
    .hero-text h2 {
      font-size: 1.3rem;
    }
  }
</style>

<div class="profile-wrapper">

  <!-- ===== HERO BANNER ===== -->
  <div class="profile-hero-banner">
    <div class="hero-content">
      <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.name) %>&background=fff&color=0d6efd&size=128&bold=true" 
           alt="<%= user.name %>" class="hero-avatar" />
      <div class="hero-text">
        <h2>Dr. <%= user.name %></h2>
        <p><i class="fa-solid fa-phone me-2"></i><%= user.phone %></p>
        <div class="hero-badge">
          <i class="fa-solid fa-shield-halved"></i>
          <%= user.role === 'admin' ? 'Administrator' : 'Doctor' %>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== STATS ROW ===== -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-icon patients"><i class="fa-solid fa-users"></i></div>
      <h3 class="stat-number"><%= patientCount %></h3>
      <p class="stat-label">Patients</p>
    </div>
    <div class="stat-card">
      <div class="stat-icon medicines"><i class="fa-solid fa-pills"></i></div>
      <h3 class="stat-number"><%= medicineCount %></h3>
      <p class="stat-label">Medicines</p>
    </div>
    <div class="stat-card">
      <div class="stat-icon visits"><i class="fa-solid fa-stethoscope"></i></div>
      <h3 class="stat-number"><%= visitsThisMonth %></h3>
      <p class="stat-label">Visits This Month</p>
    </div>
  </div>

  <!-- ===== TWO COLUMN CONTENT ===== -->
  <div class="row">
    <!-- LEFT COLUMN -->
    <div class="col-lg-6">

      <!-- Profile Details -->
      <div class="profile-card">
        <div class="section-header">
          <div class="section-icon primary"><i class="fa-solid fa-user"></i></div>
          <span class="section-title-text">Profile Details</span>
        </div>
        <div class="info-list">
          <div class="info-item">
            <div class="info-left">
              <i class="fa-solid fa-user-tag primary-icon"></i>
              <span class="info-label-text">Role</span>
            </div>
            <span class="info-value-text">
              <% if (user.role === 'admin') { %>
                <span class="badge bg-dark">Administrator</span>
              <% } else { %>
                <span class="badge bg-primary">Doctor</span>
              <% } %>
            </span>
          </div>
          <div class="info-item">
            <div class="info-left">
              <i class="fa-solid fa-phone primary-icon"></i>
              <span class="info-label-text">Phone</span>
            </div>
            <span class="info-value-text"><%= user.phone %></span>
          </div>
          <div class="info-item">
            <div class="info-left">
              <i class="fa-regular fa-calendar primary-icon"></i>
              <span class="info-label-text">Member Since</span>
            </div>
            <span class="info-value-text"><%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %></span>
          </div>
        </div>
      </div>

      <!-- Subscription Plan -->
      <div class="profile-card">
        <div class="section-header">
          <div class="section-icon orange"><i class="fa-solid fa-crown"></i></div>
          <span class="section-title-text">Subscription Plan</span>
        </div>
        <div class="info-list">
          <div class="info-item">
            <div class="info-left">
              <i class="fa-solid fa-gem orange-icon"></i>
              <span class="info-label-text">Current Plan</span>
            </div>
            <span class="info-value-text">Pro</span>
          </div>
          <div class="info-item">
            <div class="info-left">
              <i class="fa-solid fa-shield-halved orange-icon"></i>
              <span class="info-label-text">Status</span>
            </div>
            <span class="info-value-text">
              <% if (user.isActive && !isExpired) { %>
                <span class="plan-status active"><i class="fa-solid fa-circle"></i>Active Plan</span>
              <% } else { %>
                <span class="plan-status expired"><i class="fa-solid fa-circle"></i>Plan Inactive</span>
              <% } %>
            </span>
          </div>
          <% if (user.subscriptionEndsAt) { %>
            <div class="info-item">
              <div class="info-left">
                <i class="fa-regular fa-clock orange-icon"></i>
                <span class="info-label-text">Expires On</span>
              </div>
              <span class="info-value-text"><%= new Date(user.subscriptionEndsAt).toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
            </div>
          <% } %>
        </div>
        <% if (isExpired) { %>
          <div class="mt-3">
            <a href="/support" class="btn btn-warning w-100 fw-bold py-2">
              <i class="fa-solid fa-bolt me-2"></i>Activate Now
            </a>
          </div>
        <% } %>
      </div>

    </div>

    <!-- RIGHT COLUMN -->
    <div class="col-lg-6">

      <!-- Clinic Information -->
      <div class="profile-card">
        <div class="section-header">
          <div class="section-icon teal"><i class="fa-solid fa-hospital"></i></div>
          <span class="section-title-text">Clinic Information</span>
        </div>
        <% if (clinic) { %>
          <div class="info-list">
            <div class="info-item">
              <div class="info-left">
                <i class="fa-solid fa-hospital teal-icon"></i>
                <span class="info-label-text">Clinic Name</span>
              </div>
              <span class="info-value-text"><%= clinic.name %></span>
            </div>
            <% if (clinic.location) { %>
              <div class="info-item">
                <div class="info-left">
                  <i class="fa-solid fa-location-dot teal-icon"></i>
                  <span class="info-label-text">Location</span>
                </div>
                <span class="info-value-text"><%= clinic.location %></span>
              </div>
            <% } %>
            <div class="info-item">
              <div class="info-left">
                <i class="fa-solid fa-users teal-icon"></i>
                <span class="info-label-text">Total Patients</span>
              </div>
              <span class="info-value-text"><%= patientCount %></span>
            </div>
            <div class="info-item">
              <div class="info-left">
                <i class="fa-solid fa-pills teal-icon"></i>
                <span class="info-label-text">Medicines Stock</span>
              </div>
              <span class="info-value-text"><%= medicineCount %></span>
            </div>
            <div class="info-item">
              <div class="info-left">
                <i class="fa-solid fa-circle-check teal-icon"></i>
                <span class="info-label-text">Status</span>
              </div>
              <span class="info-value-text">
                <span class="badge bg-success"><i class="fa-solid fa-circle me-1" style="font-size:0.5rem;"></i>Active</span>
              </span>
            </div>
          </div>
        <% } else { %>
          <div class="no-clinic-alert">
            <i class="fa-solid fa-hospital-user"></i>
            <p>No clinic registered yet.<br><a href="/create-clinic">Create your clinic now</a></p>
          </div>
        <% } %>
      </div>

      <!-- Quick Actions -->
      <div class="profile-card">
        <div class="section-header">
          <div class="section-icon purple"><i class="fa-solid fa-bolt"></i></div>
          <span class="section-title-text">Quick Actions</span>
        </div>
        <div class="actions-flex">
          <% if (clinic) { %>
            <a href="/medicines" class="action-item">
              <i class="fa-solid fa-pen-to-square"></i>Edit Clinic
            </a>
          <% } else { %>
            <a href="/create-clinic" class="action-item">
              <i class="fa-solid fa-plus"></i>Create Clinic
            </a>
          <% } %>
          <a href="/support" class="action-item">
            <i class="fa-solid fa-lock"></i>Change Password
          </a>
          <a href="/support" class="action-item">
            <i class="fa-solid fa-headset"></i>Contact Support
          </a>
          <form id="logoutFormProfile" action="/logout" method="POST" style="margin:0;">
            <button type="submit" class="action-item danger w-100">
              <i class="fa-solid fa-arrow-right-from-bracket"></i>Logout
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>

  <!-- Support Card -->
  <div class="support-card">
    <div class="support-icon"><i class="fa-brands fa-whatsapp"></i></div>
    <div class="support-text">
      <h5>Need Help?</h5>
      <p>Quick support available on WhatsApp</p>
    </div>
    <a href="https://wa.me/918950817515" target="_blank" rel="noopener noreferrer" class="support-btn">
      <i class="fa-brands fa-whatsapp me-2"></i>Chat Now
    </a>
  </div>

</div>

